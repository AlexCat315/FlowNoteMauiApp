<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:homeViews="clr-namespace:FlowNoteMauiApp.Views.Home"
    xmlns:editorViews="clr-namespace:FlowNoteMauiApp.Views.Editor"
    xmlns:settingsViews="clr-namespace:FlowNoteMauiApp.Views.Settings"
    xmlns:sharedViews="clr-namespace:FlowNoteMauiApp.Views.Shared"
    x:Class="FlowNoteMauiApp.MainPage"
    BackgroundColor="{AppThemeBinding Light=#F8F8FA, Dark=#182434}"
>
    <ContentPage.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary
                    Source="/Resources/Styles/MainPageStyles.xaml"
                />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <Grid x:Name="EditorHost" ZIndex="0" />

        <homeViews:HomePanelView x:Name="HomePanelView" />
        <editorViews:EditorChromeView
            x:Name="EditorChromeView"
            InputTransparent="True"
            CascadeInputTransparent="False"
            VerticalOptions="Fill"
            HorizontalOptions="Fill"
            ZIndex="120"
        />
        <sharedViews:DrawerOverlayView
            x:Name="DrawerOverlayView"
            ZIndex="2200"
            IsVisible="False"
            InputTransparent="True"
        />
        <settingsViews:SettingsOverlayView
            x:Name="SettingsOverlayView"
            ZIndex="2300"
            IsVisible="False"
            InputTransparent="True"
        />
        <sharedViews:StatusToastView
            x:Name="StatusToastView"
            ZIndex="2400"
            InputTransparent="True"
        />

        <Grid
            x:Name="ImportProgressOverlay"
            IsVisible="False"
            InputTransparent="True"
            BackgroundColor="#55000000"
            ZIndex="2600"
        >
            <Border
                HorizontalOptions="Center"
                VerticalOptions="Center"
                WidthRequest="296"
                MaximumWidthRequest="320"
                Padding="16,14"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1F2E43}"
                Stroke="{AppThemeBinding Light=#DCE3EE, Dark=#3A4F69}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 14"
            >
                <VerticalStackLayout Spacing="10">
                    <Label
                        x:Name="ImportProgressTitleLabel"
                        Text="Importing PDF"
                        FontFamily="OpenSansSemibold"
                        FontSize="15"
                        HorizontalTextAlignment="Center"
                        TextColor="{AppThemeBinding Light=#1C1C1E, Dark=#F2F2F7}"
                    />
                    <ProgressBar
                        x:Name="ImportProgressBar"
                        Progress="0"
                        HeightRequest="6"
                        ProgressColor="#4A90E2"
                        BackgroundColor="{AppThemeBinding Light=#E8EDF4, Dark=#324860}"
                    />
                    <Label
                        x:Name="ImportProgressDetailLabel"
                        Text="Preparing..."
                        FontFamily="OpenSansRegular"
                        FontSize="12"
                        HorizontalTextAlignment="Center"
                        TextColor="{AppThemeBinding Light=#636366, Dark=#B9C2CF}"
                    />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
