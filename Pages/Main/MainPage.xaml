<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FlowNoteMauiApp.MainPage"
             BackgroundColor="{AppThemeBinding Light=#F8F8FA, Dark=#182434}">
    <ContentPage.Resources>
        <Color x:Key="AccentBlue">#4A90E2</Color>
        <Color x:Key="AccentBlueSoft">#E8F4FD</Color>
        <Color x:Key="AccentBlueDark">#357ABD</Color>
        <Color x:Key="TextPrimaryLight">#1C1C1E</Color>
        <Color x:Key="TextPrimaryDark">#F2F2F7</Color>
        <Color x:Key="TextSecondaryLight">#636366</Color>
        <Color x:Key="TextSecondaryDark">#AEAEB2</Color>
        <Color x:Key="SurfaceSoft">#F7FAFF</Color>
        <Color x:Key="SurfaceSoftDark">#223247</Color>

        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="OpenSansSemibold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="BorderWidth" Value="0" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="MinimumHeightRequest" Value="38" />
        </Style>

        <Style x:Key="HeaderIconButton" TargetType="ImageButton">
            <Setter Property="WidthRequest" Value="40" />
            <Setter Property="HeightRequest" Value="40" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="9" />
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource BackgroundPrimary}, Dark={StaticResource Gray800}}" />
            <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray700}}" />
            <Setter Property="BorderWidth" Value="1" />
        </Style>

        <Style x:Key="ToolbarIconButton" TargetType="ImageButton" BasedOn="{StaticResource HeaderIconButton}">
            <Setter Property="WidthRequest" Value="34" />
            <Setter Property="HeightRequest" Value="34" />
            <Setter Property="CornerRadius" Value="17" />
            <Setter Property="Padding" Value="7" />
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F4F5F8, Dark=#2B3D57}" />
            <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}" />
        </Style>

        <Style x:Key="ToolbarIconButtonSelected" TargetType="ImageButton" BasedOn="{StaticResource ToolbarIconButton}">
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ToolSelected}, Dark={StaticResource AccentBlueDark}}" />
            <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource PrimaryBlue}, Dark={StaticResource PrimaryBlueLight}}" />
        </Style>

        <Style x:Key="ToolbarToolIconButton" TargetType="ImageButton">
            <Setter Property="WidthRequest" Value="32" />
            <Setter Property="HeightRequest" Value="32" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="BorderWidth" Value="1" />
            <Setter Property="BorderColor" Value="Transparent" />
        </Style>

        <Style x:Key="ToolbarToolIconButtonSelected" TargetType="ImageButton" BasedOn="{StaticResource ToolbarToolIconButton}">
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ToolSelected}, Dark={StaticResource AccentBlueDark}}" />
            <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource PrimaryBlue}, Dark={StaticResource PrimaryBlueLight}}" />
        </Style>

        <Style x:Key="PanelCard" TargetType="Border">
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource BackgroundPrimary}, Dark={StaticResource Gray800}}" />
            <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray700}}" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="StrokeShape" Value="RoundRectangle 18" />
            <Setter Property="Shadow">
                <Shadow Brush="#1F2C3E1F" Radius="16" Offset="0,4" Opacity="0.85" />
            </Setter>
        </Style>

        <Style x:Key="FloatingIconButton" TargetType="ImageButton">
            <Setter Property="WidthRequest" Value="64" />
            <Setter Property="HeightRequest" Value="64" />
            <Setter Property="CornerRadius" Value="32" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="BackgroundColor" Value="{StaticResource PrimaryBlue}" />
            <Setter Property="Shadow">
                <Shadow Brush="#334A90E2" Offset="0,8" Radius="20" Opacity="1" />
            </Setter>
        </Style>

        <Style x:Key="DrawerItemButton" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="HorizontalOptions" Value="Fill" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="Padding" Value="10,11" />
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style x:Key="SettingRow" TargetType="Border">
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource BackgroundPrimary}, Dark={StaticResource Gray800}}" />
            <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray700}}" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="StrokeShape" Value="RoundRectangle 14" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="ColorButton" TargetType="Button">
            <Setter Property="WidthRequest" Value="30" />
            <Setter Property="HeightRequest" Value="30" />
            <Setter Property="CornerRadius" Value="15" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderWidth" Value="2" />
            <Setter Property="BorderColor" Value="Transparent" />
        </Style>

        <Style x:Key="InputModeItemButton" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="Padding" Value="8,10" />
            <Setter Property="FontSize" Value="16" />
        </Style>

        <Style x:Key="SubtleLabelChip" TargetType="Border">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="StrokeShape" Value="RoundRectangle 12" />
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource Gray700}}" />
            <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />
            <Setter Property="StrokeThickness" Value="1" />
        </Style>

        <Style x:Key="FlatTopIconButton" TargetType="ImageButton">
            <Setter Property="WidthRequest" Value="22" />
            <Setter Property="HeightRequest" Value="22" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="BorderWidth" Value="0" />
        </Style>

        <Style x:Key="FilterTabButton" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="MinimumHeightRequest" Value="30" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}" />
        </Style>
    </ContentPage.Resources>

    <Grid>
        <Grid x:Name="EditorHost" />

        <Grid x:Name="HomePanel" IsVisible="True" RowDefinitions="Auto,Auto,*" RowSpacing="0">
            <Grid Grid.Row="0" RowDefinitions="Auto,1" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1F2C3E}">
                <Grid Grid.Row="0" Padding="20,9,20,9" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                    <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                        <ImageButton Style="{StaticResource FlatTopIconButton}" Source="home_menu.svg" Clicked="OnMenuClicked" />
                        <ImageButton Style="{StaticResource FlatTopIconButton}" Source="home_bell.svg" Clicked="OnDrawerRecentClicked" />
                        <ImageButton Style="{StaticResource FlatTopIconButton}" Source="home_cloud.svg" Clicked="OnDrawerAllDocsClicked" />
                    </HorizontalStackLayout>

                    <Image Grid.Column="1"
                           Source="icon_file.svg"
                           WidthRequest="18"
                           HeightRequest="18"
                           Opacity="0.8"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />

                    <HorizontalStackLayout Grid.Column="2" Spacing="12" VerticalOptions="Center">
                        <ImageButton Style="{StaticResource FlatTopIconButton}" Source="home_done.svg" Clicked="OnDrawerFavoriteClicked" />
                        <ImageButton Style="{StaticResource FlatTopIconButton}" Source="home_search.svg" Clicked="OnHomeRefreshClicked" />
                        <ImageButton Style="{StaticResource FlatTopIconButton}" Source="home_settings.svg" Clicked="OnOpenSettingsClicked" />
                    </HorizontalStackLayout>
                </Grid>
                <BoxView Grid.Row="1" Color="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray700}}" />
            </Grid>

            <Grid Grid.Row="1" Padding="20,12,20,8" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="20">
                    <VerticalStackLayout Spacing="5">
                        <Button x:Name="FilterAllButton" Style="{StaticResource FilterTabButton}" Text="全部" Clicked="OnHomeFilterAllClicked" />
                        <BoxView x:Name="FilterAllIndicator" HeightRequest="2" WidthRequest="30" HorizontalOptions="Center" Color="{StaticResource PrimaryBlue}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="5">
                        <Button x:Name="FilterPdfButton" Style="{StaticResource FilterTabButton}" Text="PDF" Clicked="OnHomeFilterPdfClicked" />
                        <BoxView x:Name="FilterPdfIndicator" HeightRequest="2" WidthRequest="30" HorizontalOptions="Center" Color="{StaticResource PrimaryBlue}" IsVisible="False" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="5">
                        <Button x:Name="FilterNoteButton" Style="{StaticResource FilterTabButton}" Text="笔记" Clicked="OnHomeFilterNoteClicked" />
                        <BoxView x:Name="FilterNoteIndicator" HeightRequest="2" WidthRequest="30" HorizontalOptions="Center" Color="{StaticResource PrimaryBlue}" IsVisible="False" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="5">
                        <Button x:Name="FilterFolderButton" Style="{StaticResource FilterTabButton}" Text="文件夹" Clicked="OnHomeFilterFolderClicked" />
                        <BoxView x:Name="FilterFolderIndicator" HeightRequest="2" WidthRequest="36" HorizontalOptions="Center" Color="{StaticResource PrimaryBlue}" IsVisible="False" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>

                <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                    <Border WidthRequest="16"
                            HeightRequest="16"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 4">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#E95077" Offset="0" />
                                <GradientStop Color="#3E76FF" Offset="0.55" />
                                <GradientStop Color="#48C39F" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <ImageButton Style="{StaticResource FlatTopIconButton}" Source="home_reorder.svg" Clicked="OnHomeSortClicked" />
                    <ImageButton Style="{StaticResource FlatTopIconButton}" Source="home_sort.svg" Clicked="OnHomeSortClicked" />
                    <Button x:Name="HomeSortButton"
                            Style="{StaticResource BaseButtonStyle}"
                            Text="排序"
                            FontSize="14"
                            Padding="0"
                            BackgroundColor="Transparent"
                            Clicked="OnHomeSortClicked" />
                </HorizontalStackLayout>
            </Grid>

            <Grid Grid.Row="2">
                <ScrollView>
                    <VerticalStackLayout Spacing="8" Padding="44,4,44,120">
                        <FlexLayout x:Name="HomeNotesList"
                                    Direction="Row"
                                    Wrap="Wrap"
                                    AlignItems="Start"
                                    AlignContent="Start"
                                    JustifyContent="Start" />
                    </VerticalStackLayout>
                </ScrollView>

                <VerticalStackLayout HorizontalOptions="End"
                                     VerticalOptions="End"
                                     Spacing="12"
                                     Margin="0,0,30,24">
                    <ImageButton x:Name="QuickPenButton"
                                 Style="{StaticResource FloatingIconButton}"
                                 WidthRequest="48"
                                 HeightRequest="48"
                                 CornerRadius="24"
                                 Padding="12"
                                 BackgroundColor="{StaticResource PrimaryBlueLight}"
                                 Source="icon_pencil.svg"
                                 Clicked="OnHomeQuickPenClicked" />
                    <ImageButton Style="{StaticResource FloatingIconButton}"
                                 WidthRequest="58"
                                 HeightRequest="58"
                                 CornerRadius="29"
                                 Padding="15"
                                 Source="icon_plus.svg"
                                 Clicked="OnHomeImportLocalClicked" />
                </VerticalStackLayout>

                <Entry x:Name="HomeSearchEntry"
                       IsVisible="False"
                       TextChanged="OnHomeSearchTextChanged" />
                <Label x:Name="HomeCountLabel" IsVisible="False" Text="0 个文档" />
                <Entry x:Name="HomeUrlEntry" IsVisible="False" />
            </Grid>
        </Grid>

        <Border x:Name="TopBarPanel"
                IsVisible="False"
                HorizontalOptions="Fill"
                VerticalOptions="Start"
                Margin="12,8,12,0"
                Padding="10,8"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#223247}"
                Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 20"
                Opacity="0.98">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                    <ImageButton Grid.Column="0"
                                 Style="{StaticResource ToolbarIconButton}"
                                 Source="icon_arrow_left.svg"
                                 Clicked="OnHomeClicked" />

                    <ScrollView Grid.Column="1" Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                        <HorizontalStackLayout x:Name="EditorTabsHost" Spacing="8" />
                    </ScrollView>

                    <HorizontalStackLayout Grid.Column="2" Spacing="6" VerticalOptions="Center">
                        <ImageButton Style="{StaticResource ToolbarIconButton}"
                                     Source="icon_plus.svg"
                                     Clicked="OnHomeImportLocalClicked" />
                        <ImageButton Style="{StaticResource ToolbarIconButton}"
                                     Source="icon_settings.svg"
                                     Clicked="OnOpenSettingsClicked" />
                        <ImageButton Style="{StaticResource ToolbarIconButton}"
                                     Source="icon_search.svg"
                                     Clicked="OnEditorSearchClicked" />
                        <ImageButton Style="{StaticResource ToolbarIconButton}"
                                     Source="icon_layers_selected.svg"
                                     Clicked="OnLayerToggleClicked" />
                    </HorizontalStackLayout>
                </Grid>

                <Border Grid.Row="1"
                        Padding="6,4"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E2D43}"
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12">
                    <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                        <HorizontalStackLayout Spacing="4">
                            <ImageButton x:Name="UndoButton" Style="{StaticResource ToolbarToolIconButton}" Source="icon_arrow_back_up.svg" Clicked="OnUndoClicked" />
                            <ImageButton x:Name="RedoButton" Style="{StaticResource ToolbarToolIconButton}" Source="icon_arrow_forward_up.svg" Clicked="OnRedoClicked" />
                            <BoxView WidthRequest="1" HeightRequest="18" VerticalOptions="Center" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" Margin="1,0" />

                            <ImageButton x:Name="PenModeButton" Style="{StaticResource ToolbarToolIconButtonSelected}" Source="icon_pencil.svg" Clicked="OnPenModeClicked" />
                            <ImageButton x:Name="HighlighterButton" Style="{StaticResource ToolbarToolIconButton}" Source="icon_brush.svg" Clicked="OnHighlighterClicked" />
                            <ImageButton x:Name="EraserButton" Style="{StaticResource ToolbarToolIconButton}" Source="icon_eraser.svg" Clicked="OnEraserClicked" />
                            <ImageButton x:Name="ClearButton2" Style="{StaticResource ToolbarToolIconButton}" Source="icon_trash.svg" Clicked="OnClearClicked" />
                            <ImageButton x:Name="DrawingToggleButton" Style="{StaticResource ToolbarToolIconButtonSelected}" Source="icon_pencil.svg" Clicked="OnDrawingToggleClicked" />
                            <ImageButton Style="{StaticResource ToolbarToolIconButton}" Source="icon_layers_selected.svg" Clicked="OnLayerToggleClicked" />
                            <BoxView WidthRequest="1" HeightRequest="18" VerticalOptions="Center" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" Margin="1,0" />

                            <ImageButton x:Name="TextToolButton" Style="{StaticResource ToolbarToolIconButton}" Source="icon_text.svg" Clicked="OnTextToolClicked" />
                            <ImageButton x:Name="ImageToolButton" Style="{StaticResource ToolbarToolIconButton}" Source="icon_image.svg" Clicked="OnImageToolClicked" />
                            <ImageButton x:Name="ShapeToolButton" Style="{StaticResource ToolbarToolIconButton}" Source="icon_shape.svg" Clicked="OnShapeToolClicked" />
                            <BoxView WidthRequest="1" HeightRequest="18" VerticalOptions="Center" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" Margin="1,0" />

                            <ImageButton x:Name="PrevPageButton" Style="{StaticResource ToolbarToolIconButton}" Source="icon_arrow_left.svg" Clicked="OnPrevPageClicked" />
                            <Border Padding="8,0"
                                    HeightRequest="28"
                                    VerticalOptions="Center"
                                    BackgroundColor="{AppThemeBinding Light=#F7F8FA, Dark=#2A3C55}"
                                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 9">
                                <Label x:Name="PageInfoLabel"
                                       Text="Page: 1/1"
                                       VerticalOptions="Center"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                            </Border>
                            <ImageButton x:Name="NextPageButton" Style="{StaticResource ToolbarToolIconButton}" Source="icon_arrow_right.svg" Clicked="OnNextPageClicked" />
                            <BoxView WidthRequest="1" HeightRequest="18" VerticalOptions="Center" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" Margin="1,0" />

                            <Button x:Name="ColorBlack" Style="{StaticResource ColorButton}" BackgroundColor="#111111" Clicked="OnColorBlackClicked" />
                            <Button x:Name="ColorBlue" Style="{StaticResource ColorButton}" BackgroundColor="#2F74D0" Clicked="OnColorBlueClicked" />
                            <Button x:Name="ColorRed" Style="{StaticResource ColorButton}" BackgroundColor="#E23B30" Clicked="OnColorRedClicked" />
                            <Button x:Name="ColorGreen" Style="{StaticResource ColorButton}" BackgroundColor="#2CC66D" Clicked="OnColorGreenClicked" />
                            <Button x:Name="ColorOrange" Style="{StaticResource ColorButton}" BackgroundColor="#F4B100" Clicked="OnColorOrangeClicked" />
                            <Button x:Name="ColorWhite" Style="{StaticResource ColorButton}" BackgroundColor="#FFFFFF" BorderColor="#CBD5E1" BorderWidth="1" Clicked="OnColorWhiteClicked" />
                        </HorizontalStackLayout>
                    </ScrollView>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="InputModePanel"
                IsVisible="False"
                VerticalOptions="Start"
                HorizontalOptions="Start"
                Margin="18,112,0,0"
                Padding="12"
                WidthRequest="356"
                Style="{StaticResource PanelCard}">
            <VerticalStackLayout Spacing="6">
                <Label Text="输入方式"
                       FontFamily="OpenSansSemibold"
                       FontSize="14"
                       TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}" />
                <Label Text="手指/电容笔模式下：单指书写，双指翻页或移动页面"
                       FontSize="12"
                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                    <Button Grid.Column="0"
                            Style="{StaticResource InputModeItemButton}"
                            Text="手写笔"
                            Clicked="OnInputModePenClicked" />
                    <Label x:Name="InputModePenCheck"
                           Grid.Column="1"
                           VerticalOptions="Center"
                           Text="✓"
                           FontSize="24"
                           TextColor="{StaticResource PrimaryBlue}" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                    <Button Grid.Column="0"
                            Style="{StaticResource InputModeItemButton}"
                            Text="手指/电容笔（双指移动）"
                            Clicked="OnInputModeFingerClicked" />
                    <Label x:Name="InputModeFingerCheck"
                           Grid.Column="1"
                           VerticalOptions="Center"
                           Text="✓"
                           FontSize="24"
                           TextColor="{StaticResource PrimaryBlue}"
                           IsVisible="False" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                    <Button Grid.Column="0"
                            Style="{StaticResource InputModeItemButton}"
                            Text="点读模式"
                            Clicked="OnInputModeReadClicked" />
                    <Label x:Name="InputModeReadCheck"
                           Grid.Column="1"
                           VerticalOptions="Center"
                           Text="✓"
                           FontSize="24"
                           TextColor="{StaticResource PrimaryBlue}"
                           IsVisible="False" />
                </Grid>
            </VerticalStackLayout>
        </Border>

        <Border x:Name="DrawingToolbarPanel"
                IsVisible="False"
                VerticalOptions="Start"
                Margin="18,122,18,0"
                Padding="12,10"
                Style="{StaticResource PanelCard}"
                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceSoft}, Dark={StaticResource SurfaceSoftDark}}">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                <Label Grid.Column="0"
                       VerticalOptions="Center"
                       Text="笔宽"
                       FontFamily="OpenSansSemibold"
                       FontSize="13"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

                <Border Grid.Column="1"
                        Padding="10,2"
                        VerticalOptions="Center"
                        BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundSecondary}, Dark={StaticResource Gray800}}"
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 14">
                    <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                        <Slider x:Name="StrokeWidthSlider"
                                WidthRequest="160"
                                Minimum="1"
                                Maximum="20"
                                Value="3"
                                ValueChanged="OnStrokeWidthChanged"
                                VerticalOptions="Center" />
                        <Label x:Name="StrokeWidthLabel"
                               Text="3"
                               WidthRequest="26"
                               FontFamily="OpenSansSemibold"
                               FontSize="12"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                    </HorizontalStackLayout>
                </Border>

                <ImageButton Grid.Column="2"
                             Style="{StaticResource ToolbarIconButton}"
                             WidthRequest="40"
                             HeightRequest="40"
                             Source="icon_layers_selected.svg"
                             Clicked="OnLayerToggleClicked" />
                <ImageButton Grid.Column="3"
                             Style="{StaticResource ToolbarIconButton}"
                             WidthRequest="40"
                             HeightRequest="40"
                             Source="icon_x.svg"
                             Clicked="OnDrawingToolbarCloseClicked" />
            </Grid>
        </Border>

        <Border x:Name="LayerPanel"
                IsVisible="False"
                VerticalOptions="Fill"
                HorizontalOptions="End"
                WidthRequest="252"
                Margin="0,72,14,100"
                Padding="12"
                Style="{StaticResource PanelCard}"
                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceSoft}, Dark={StaticResource SurfaceSoftDark}}">
            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
                <Label Grid.Row="0"
                       Text="图层"
                       FontFamily="OpenSansSemibold"
                       FontSize="16"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                <ScrollView Grid.Row="1">
                    <VerticalStackLayout x:Name="LayerList" Spacing="6" />
                </ScrollView>
                <HorizontalStackLayout Grid.Row="2" Spacing="8" HorizontalOptions="Center">
                    <ImageButton Style="{StaticResource ToolbarIconButton}"
                                 WidthRequest="40"
                                 HeightRequest="40"
                                 Source="icon_plus.svg"
                                 Clicked="OnAddLayerClicked" />
                    <ImageButton Style="{StaticResource ToolbarIconButton}"
                                 WidthRequest="40"
                                 HeightRequest="40"
                                 Source="icon_minus.svg"
                                 Clicked="OnDeleteLayerClicked" />
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <Grid x:Name="HomeDrawerOverlay"
              IsVisible="False"
              BackgroundColor="#6A0E1828">
            <Grid ColumnDefinitions="330,*">
                <Border Grid.Column="0"
                        Margin="10,10,0,10"
                        Padding="14,12,14,14"
                        Style="{StaticResource PanelCard}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceSoft}, Dark={StaticResource SurfaceSoftDark}}">
                    <ScrollView>
                        <VerticalStackLayout Spacing="10">
                            <Grid Padding="0,2,0,6" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <Border WidthRequest="44"
                                        HeightRequest="44"
                                        StrokeShape="RoundRectangle 22"
                                        Stroke="{AppThemeBinding Light=#D3DAE8, Dark=#4B607D}"
                                        StrokeThickness="1"
                                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A3A52}">
                                    <Image Source="icon_file.svg" WidthRequest="22" HeightRequest="22" VerticalOptions="Center" HorizontalOptions="Center" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                    <Label Text="登录/注册"
                                           FontFamily="OpenSansSemibold"
                                           FontSize="16"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                                    <Label Text="同步你的学习进度"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                                </VerticalStackLayout>
                                <ImageButton Grid.Column="2"
                                             Style="{StaticResource HeaderIconButton}"
                                             Source="icon_x.svg"
                                             Clicked="OnMenuClicked" />
                            </Grid>

                            <Border Style="{StaticResource PanelCard}"
                                    Padding="8"
                                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#25344A}">
                                <VerticalStackLayout Spacing="2">
                                    <Button Style="{StaticResource DrawerItemButton}" Text="所有文档" Clicked="OnDrawerAllDocsClicked" />
                                    <Button Style="{StaticResource DrawerItemButton}" Text="最近使用" Clicked="OnDrawerRecentClicked" />
                                    <Button Style="{StaticResource DrawerItemButton}" Text="我的收藏" Clicked="OnDrawerFavoriteClicked" />
                                    <Button Style="{StaticResource DrawerItemButton}" Text="回收站" Clicked="OnDrawerTrashClicked" />
                                </VerticalStackLayout>
                            </Border>

                            <Label Margin="0,8,0,0"
                                   Text="我的标签"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
                            <Border Style="{StaticResource PanelCard}"
                                    Padding="8"
                                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#25344A}">
                                <VerticalStackLayout Spacing="2">
                                    <Button Style="{StaticResource DrawerItemButton}" Text="编辑标签" Clicked="OnDrawerEditTagsClicked" />
                                    <Button Style="{StaticResource DrawerItemButton}" Text="创建新标签" Clicked="OnDrawerCreateTagClicked" />
                                </VerticalStackLayout>
                            </Border>

                            <Label Margin="0,8,0,0"
                                   Text="我的应用"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
                            <Border Style="{StaticResource PanelCard}"
                                    Padding="8"
                                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#25344A}">
                                <VerticalStackLayout Spacing="2">
                                    <Button Style="{StaticResource DrawerItemButton}" Text="帮助中心" Clicked="OnDrawerHelpClicked" />
                                    <Button Style="{StaticResource DrawerItemButton}" Text="关于我们" Clicked="OnDrawerAboutClicked" />
                                    <Button Style="{StaticResource DrawerItemButton}" Text="获取折扣" Clicked="OnDrawerDiscountClicked" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Margin="0,8,0,0"
                                    Padding="12"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 14">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#4A90E2" Offset="0" />
                                        <GradientStop Color="#6A7FF0" Offset="0.6" />
                                        <GradientStop Color="#57B8E5" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <Image Source="icon_file.svg" WidthRequest="36" HeightRequest="36" Opacity="0.9" />
                                    <Label Grid.Column="1"
                                           Text="注册即领免费试用\n解锁全功能笔记工作流"
                                           FontFamily="OpenSansSemibold"
                                           FontSize="13"
                                           TextColor="White" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>
                    </ScrollView>
                </Border>

                <BoxView Grid.Column="1" Color="Transparent">
                    <BoxView.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDrawerBackdropTapped" />
                    </BoxView.GestureRecognizers>
                </BoxView>
            </Grid>
        </Grid>

        <Grid x:Name="SettingsOverlay"
              IsVisible="False"
              BackgroundColor="#730A1322">
            <BoxView Color="Transparent">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSettingsOverlayTapped" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <Border x:Name="SettingsPanel"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    WidthRequest="720"
                    MaximumWidthRequest="900"
                    Margin="20"
                    Padding="22,18,22,20"
                    BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundModal}, Dark=#1F2C3E}"
                    Stroke="{AppThemeBinding Light={StaticResource Gray100}, Dark=#435975}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 24">
                <ScrollView>
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <ImageButton x:Name="SettingsBackButton"
                                         WidthRequest="44"
                                         HeightRequest="44"
                                         CornerRadius="22"
                                         Padding="10"
                                         IsVisible="False"
                                         BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2B3D57}"
                                         BorderColor="{AppThemeBinding Light=#D5DBE8, Dark=#697F9F}"
                                         BorderWidth="1"
                                         Source="icon_arrow_left.svg"
                                         Clicked="OnSettingsBackClicked" />
                            <Label x:Name="SettingsTitleLabel"
                                   Grid.Column="1"
                                   Text="设置"
                                   VerticalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="30"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                            <ImageButton Grid.Column="2"
                                         WidthRequest="44"
                                         HeightRequest="44"
                                         CornerRadius="22"
                                         Padding="10"
                                         BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2B3D57}"
                                         BorderColor="{AppThemeBinding Light=#D5DBE8, Dark=#697F9F}"
                                         BorderWidth="1"
                                         Source="icon_x.svg"
                                         Clicked="OnSettingsCloseClicked" />
                        </Grid>

                        <VerticalStackLayout x:Name="SettingsHomeView" Spacing="12">
                            <Label x:Name="SettingsHomeHintLabel"
                                   Text="页面、显示和语言设置"
                                   Margin="0,-6,0,0"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />

                            <Border Style="{StaticResource PanelCard}" Padding="0">
                                <VerticalStackLayout Spacing="0">
                                    <Border Style="{StaticResource SettingRow}">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnOpenPageSettingsTapped" />
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                                            <Image Source="icon_file.svg" WidthRequest="24" HeightRequest="24" />
                                            <Label Grid.Column="1" Text="页面设置" FontSize="16" VerticalOptions="Center" />
                                            <Label x:Name="PageSettingsSummaryLabel"
                                                   Grid.Column="2"
                                                   Text="连续滚动"
                                                   FontSize="15"
                                                   VerticalOptions="Center"
                                                   TextColor="{AppThemeBinding Light=#9AA3B2, Dark=#9FB0C9}" />
                                            <Label Grid.Column="3"
                                                   Text="›"
                                                   FontSize="22"
                                                   VerticalOptions="Center"
                                                   TextColor="{AppThemeBinding Light=#939DAC, Dark=#9FB0C9}" />
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingRow}">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnOpenDisplaySettingsTapped" />
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                                            <Image Source="icon_eye.svg" WidthRequest="24" HeightRequest="24" />
                                            <Label Grid.Column="1" Text="显示" FontSize="16" VerticalOptions="Center" />
                                            <Label x:Name="DisplaySettingsSummaryLabel"
                                                   Grid.Column="2"
                                                   Text="跟随系统"
                                                   FontSize="15"
                                                   VerticalOptions="Center"
                                                   TextColor="{AppThemeBinding Light=#9AA3B2, Dark=#9FB0C9}" />
                                            <Label Grid.Column="3"
                                                   Text="›"
                                                   FontSize="22"
                                                   VerticalOptions="Center"
                                                   TextColor="{AppThemeBinding Light=#939DAC, Dark=#9FB0C9}" />
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingRow}">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnOpenLanguageSettingsTapped" />
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                                            <Image Source="icon_search.svg" WidthRequest="24" HeightRequest="24" />
                                            <Label Grid.Column="1" Text="语言与日期" FontSize="16" VerticalOptions="Center" />
                                            <Label x:Name="LanguageSettingsSummaryLabel"
                                                   Grid.Column="2"
                                                   Text="简体中文"
                                                   FontSize="15"
                                                   VerticalOptions="Center"
                                                   TextColor="{AppThemeBinding Light=#9AA3B2, Dark=#9FB0C9}" />
                                            <Label Grid.Column="3"
                                                   Text="›"
                                                   FontSize="22"
                                                   VerticalOptions="Center"
                                                   TextColor="{AppThemeBinding Light=#939DAC, Dark=#9FB0C9}" />
                                        </Grid>
                                    </Border>
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout x:Name="PageSettingsView" IsVisible="False" Spacing="12">
                            <Border Style="{StaticResource PanelCard}" Padding="0">
                                <VerticalStackLayout Spacing="0">
                                    <Border Style="{StaticResource SettingRow}">
                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                            <Label Text="翻页方向" FontSize="16" VerticalOptions="Center" />
                                            <Button x:Name="PageDirectionVerticalButton"
                                                    Grid.Column="1"
                                                    Text="竖向"
                                                    FontSize="13"
                                                    CornerRadius="8"
                                                    Padding="10,6"
                                                    Clicked="OnPageDirectionVerticalClicked" />
                                            <Button x:Name="PageDirectionHorizontalButton"
                                                    Grid.Column="2"
                                                    Text="横向"
                                                    FontSize="13"
                                                    CornerRadius="8"
                                                    Padding="10,6"
                                                    Clicked="OnPageDirectionHorizontalClicked" />
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingRow}">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnPageModeTapped" />
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                            <Label Text="翻页方式" FontSize="16" VerticalOptions="Center" />
                                            <Label x:Name="PageModeValueLabel"
                                                   Grid.Column="1"
                                                   FontSize="16"
                                                   VerticalOptions="Center"
                                                   TextColor="{AppThemeBinding Light=#9AA3B2, Dark=#9FB0C9}" />
                                            <Label Grid.Column="2"
                                                   Text="›"
                                                   FontSize="22"
                                                   VerticalOptions="Center"
                                                   TextColor="{AppThemeBinding Light=#939DAC, Dark=#9FB0C9}" />
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingRow}">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnFitModeTapped" />
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                            <Label Text="加页方式" FontSize="16" VerticalOptions="Center" />
                                            <Label x:Name="FitModeValueLabel"
                                                   Grid.Column="1"
                                                   FontSize="16"
                                                   VerticalOptions="Center"
                                                   TextColor="{AppThemeBinding Light=#9AA3B2, Dark=#9FB0C9}" />
                                            <Label Grid.Column="2"
                                                   Text="›"
                                                   FontSize="22"
                                                   VerticalOptions="Center"
                                                   TextColor="{AppThemeBinding Light=#939DAC, Dark=#9FB0C9}" />
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingRow}">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnPageNumberPositionTapped" />
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                            <Label Text="页码位置" FontSize="16" VerticalOptions="Center" />
                                            <Label x:Name="PageNumberPositionValueLabel"
                                                   Grid.Column="1"
                                                   FontSize="16"
                                                   VerticalOptions="Center"
                                                   TextColor="{AppThemeBinding Light=#9AA3B2, Dark=#9FB0C9}" />
                                            <Label Grid.Column="2"
                                                   Text="›"
                                                   FontSize="22"
                                                   VerticalOptions="Center"
                                                   TextColor="{AppThemeBinding Light=#939DAC, Dark=#9FB0C9}" />
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingRow}">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnTextSelectionTapped" />
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                            <Label Text="文字选取与编辑" FontSize="16" VerticalOptions="Center" />
                                            <Label x:Name="TextSelectionValueLabel"
                                                   Grid.Column="1"
                                                   FontSize="16"
                                                   VerticalOptions="Center"
                                                   TextColor="{AppThemeBinding Light=#9AA3B2, Dark=#9FB0C9}" />
                                            <Label Grid.Column="2"
                                                   Text="›"
                                                   FontSize="22"
                                                   VerticalOptions="Center"
                                                   TextColor="{AppThemeBinding Light=#939DAC, Dark=#9FB0C9}" />
                                        </Grid>
                                    </Border>
                                </VerticalStackLayout>
                            </Border>

                            <Border Style="{StaticResource PanelCard}" Padding="20,16">
                                <VerticalStackLayout Spacing="16">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                        <Label Text="页面自由移动"
                                               FontFamily="OpenSansSemibold"
                                               FontSize="18"
                                               VerticalOptions="Center" />
                                        <Switch x:Name="PageFreeMoveSwitch"
                                                Grid.Column="1"
                                                VerticalOptions="Center"
                                                Toggled="OnPageFreeMoveToggled" />
                                    </Grid>
                                    <Label Text="开启后，在双指滑动结束时继续惯性滚动，可通过阻力控制滑动衰减。"
                                           FontSize="13"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                        <Label Text="阻力" FontSize="16" VerticalOptions="Center" />
                                        <Slider x:Name="PageMoveResistanceSlider"
                                                Grid.Column="1"
                                                Minimum="0"
                                                Maximum="100"
                                                ValueChanged="OnPageMoveResistanceChanged" />
                                        <Label x:Name="PageMoveResistanceValueLabel"
                                               Grid.Column="2"
                                               FontSize="16"
                                               VerticalOptions="Center"
                                               WidthRequest="56"
                                               HorizontalTextAlignment="End" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>

                            <Border Style="{StaticResource PanelCard}" Padding="20,16">
                                <VerticalStackLayout Spacing="14">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                        <Label Text="缩放跟随"
                                               FontFamily="OpenSansSemibold"
                                               FontSize="18"
                                               VerticalOptions="Center" />
                                        <Switch x:Name="ZoomFollowSwitch"
                                                Grid.Column="1"
                                                VerticalOptions="Center"
                                                Toggled="OnZoomFollowToggled" />
                                    </Grid>
                                    <Label Text="开启后，笔迹粗细会跟随页面缩放变化；关闭后保持屏幕像素粗细。"
                                           FontSize="13"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout x:Name="DisplaySettingsView" IsVisible="False" Spacing="12">
                            <Border Style="{StaticResource PanelCard}" Padding="0">
                                <VerticalStackLayout Spacing="0">
                                    <Border Style="{StaticResource SettingRow}">
                                        <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10">
                                            <Label Text="显示模式" FontSize="16" VerticalOptions="Center" />
                                            <Button x:Name="ThemeLightButton"
                                                    Grid.Column="1"
                                                    Text="浅色"
                                                    FontSize="13"
                                                    CornerRadius="8"
                                                    Padding="10,6"
                                                    Clicked="OnThemeLightClicked" />
                                            <Button x:Name="ThemeDarkButton"
                                                    Grid.Column="2"
                                                    Text="深色"
                                                    FontSize="13"
                                                    CornerRadius="8"
                                                    Padding="10,6"
                                                    Clicked="OnThemeDarkClicked" />
                                            <Button x:Name="ThemeSystemButton"
                                                    Grid.Column="3"
                                                    Text="跟随"
                                                    FontSize="13"
                                                    CornerRadius="8"
                                                    Padding="10,6"
                                                    Clicked="OnThemeSystemClicked" />
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingRow}">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnDateFormatTapped" />
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                            <Label Text="日期格式" FontSize="16" VerticalOptions="Center" />
                                            <Label x:Name="DateFormatValueLabel"
                                                   Grid.Column="1"
                                                   FontSize="16"
                                                   VerticalOptions="Center"
                                                   TextColor="{AppThemeBinding Light=#9AA3B2, Dark=#9FB0C9}" />
                                            <Label Grid.Column="2"
                                                   Text="›"
                                                   FontSize="22"
                                                   VerticalOptions="Center"
                                                   TextColor="{AppThemeBinding Light=#939DAC, Dark=#9FB0C9}" />
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingRow}">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                            <Label Text="保持屏幕常亮" FontSize="16" VerticalOptions="Center" />
                                            <Switch x:Name="KeepScreenOnSwitch"
                                                    Grid.Column="1"
                                                    VerticalOptions="Center"
                                                    Toggled="OnKeepScreenOnToggled" />
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingRow}">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                            <Label Text="暗黑模式颜色反转" FontSize="16" VerticalOptions="Center" />
                                            <Switch x:Name="DarkModeInvertSwitch"
                                                    Grid.Column="1"
                                                    VerticalOptions="Center"
                                                    Toggled="OnDarkInvertToggled" />
                                        </Grid>
                                    </Border>
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout x:Name="LanguageSettingsView" IsVisible="False" Spacing="12">
                            <Border Style="{StaticResource PanelCard}" Padding="0">
                                <VerticalStackLayout Spacing="0">
                                    <Border Style="{StaticResource SettingRow}">
                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                            <Label Text="语言" FontSize="16" VerticalOptions="Center" />
                                            <Button x:Name="LanguageChineseButton"
                                                    Grid.Column="1"
                                                    Text="简体中文"
                                                    FontSize="13"
                                                    CornerRadius="8"
                                                    Padding="10,6"
                                                    Clicked="OnLanguageChineseClicked" />
                                            <Button x:Name="LanguageEnglishButton"
                                                    Grid.Column="2"
                                                    Text="English"
                                                    FontSize="13"
                                                    CornerRadius="8"
                                                    Padding="10,6"
                                                    Clicked="OnLanguageEnglishClicked" />
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingRow}">
                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                            <Label Text="日期格式" FontSize="16" VerticalOptions="Center" />
                                            <Label x:Name="LanguageDateFormatValueLabel"
                                                   Grid.Column="1"
                                                   FontSize="16"
                                                   VerticalOptions="Center"
                                                   TextColor="{AppThemeBinding Light=#9AA3B2, Dark=#9FB0C9}" />
                                            <Label Grid.Column="2"
                                                   Text="在显示页设置"
                                                   FontSize="14"
                                                   VerticalOptions="Center"
                                                   TextColor="{AppThemeBinding Light=#9AA3B2, Dark=#9FB0C9}" />
                                        </Grid>
                                    </Border>
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>

                        <Button x:Name="ResetSettingsButton"
                                Text="还原初始设置"
                                FontFamily="OpenSansSemibold"
                                FontSize="16"
                                HeightRequest="52"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#25344A}"
                                TextColor="#EC4F74"
                                CornerRadius="24"
                                Clicked="OnResetSettingsClicked" />

                        <VerticalStackLayout IsVisible="False" Spacing="8">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Entry x:Name="UrlEntry" Placeholder="PDF URL" />
                                <Button x:Name="LoadUrlButton" Grid.Column="1" Text="加载" Clicked="OnLoadUrlClicked" />
                            </Grid>
                            <HorizontalStackLayout Spacing="8">
                                <Button x:Name="LoadSampleButton" Text="示例" Clicked="OnLoadSampleClicked" />
                                <Button x:Name="LocalFileButton" Text="本地打开" Clicked="OnPickFileClicked" />
                            </HorizontalStackLayout>

                            <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="6">
                                <Button Grid.Column="0" Text="根目录" Clicked="OnWorkspaceRootClicked" />
                                <Button Grid.Column="1" Text="上级" Clicked="OnWorkspaceUpClicked" />
                                <Entry Grid.Column="2" x:Name="WorkspaceFolderEntry" Placeholder="/" />
                                <Button Grid.Column="3" Text="打开" Clicked="OnWorkspaceOpenFolderClicked" />
                            </Grid>
                            <HorizontalStackLayout Spacing="8">
                                <Entry x:Name="WorkspaceNewFolderEntry" Placeholder="新建文件夹" HorizontalOptions="FillAndExpand" />
                                <Button Text="创建" Clicked="OnWorkspaceCreateFolderClicked" />
                                <Button Text="刷新" Clicked="OnWorkspaceRefreshClicked" />
                            </HorizontalStackLayout>
                            <VerticalStackLayout x:Name="RecentNotesList" Spacing="4" />
                            <VerticalStackLayout x:Name="WorkspaceFolderList" Spacing="4" />
                            <VerticalStackLayout x:Name="WorkspaceNoteList" Spacing="4" />

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Entry x:Name="SearchEntry" Grid.Column="0" Placeholder="关键词" />
                                <ImageButton x:Name="SearchButton"
                                             Grid.Column="1"
                                             WidthRequest="40"
                                             HeightRequest="40"
                                             Source="icon_search.svg"
                                             Clicked="OnSearchClicked" />
                            </Grid>
                            <HorizontalStackLayout Spacing="8">
                                <ImageButton x:Name="SearchPrevButton" WidthRequest="40" HeightRequest="40" Source="icon_arrow_left.svg" Clicked="OnSearchPrevClicked" />
                                <ImageButton x:Name="SearchNextButton" WidthRequest="40" HeightRequest="40" Source="icon_arrow_right.svg" Clicked="OnSearchNextClicked" />
                                <Label x:Name="SearchStatusLabel" VerticalOptions="Center" FontSize="11" />
                            </HorizontalStackLayout>

                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                <Picker x:Name="DisplayModePicker" Title="模式" SelectedIndexChanged="OnDisplayModeChanged" />
                                <Picker Grid.Column="1" x:Name="OrientationPicker" Title="方向" SelectedIndexChanged="OnOrientationChanged" />
                                <Picker Grid.Column="2" x:Name="FitPolicyPicker" Title="适配" SelectedIndexChanged="OnFitPolicyChanged" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Slider x:Name="ZoomSlider" Minimum="0.5" Maximum="4" Value="1" ValueChanged="OnZoomSliderValueChanged" />
                                <Label x:Name="ZoomValueLabel" Grid.Column="1" Text="1.00x" WidthRequest="50" VerticalOptions="Center" />
                            </Grid>

                            <HorizontalStackLayout Spacing="8">
                                <Label Text="缩放" VerticalOptions="Center" FontSize="12" />
                                <Switch x:Name="EnableZoomSwitch" IsToggled="True" Toggled="OnEnableZoomToggled" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="翻页" VerticalOptions="Center" FontSize="12" />
                                <Switch x:Name="EnableSwipeSwitch" IsToggled="True" Toggled="OnEnableSwipeToggled" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="链接" VerticalOptions="Center" FontSize="12" />
                                <Switch x:Name="EnableLinkSwitch" IsToggled="True" Toggled="OnEnableLinkToggled" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="手指绘制" VerticalOptions="Center" FontSize="12" />
                                <Switch x:Name="EnableFingerDrawSwitch" IsToggled="False" Toggled="OnFingerDrawToggled" />
                            </HorizontalStackLayout>

                            <Label x:Name="EventInfoLabel" Text="Ready" FontSize="11" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>
            </Border>
        </Grid>

        <Border x:Name="StatusToast"
                VerticalOptions="End"
                HorizontalOptions="Center"
                Margin="0,0,0,24"
                Padding="16,8"
                BackgroundColor="#DA0B1830"
                Stroke="#2AFFFFFF"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 18"
                Opacity="0"
                IsVisible="False">
            <Label x:Name="StatusLabel"
                   FontFamily="OpenSansSemibold"
                   FontSize="12"
                   TextColor="White" />
        </Border>
    </Grid>
</ContentPage>
