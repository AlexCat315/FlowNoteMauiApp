<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FlowNoteMauiApp.MainPage">
    <ContentPage.Resources>
        <Color x:Key="PrimaryColor">#2563EB</Color>
        <Color x:Key="SurfaceColor">#FFFFFF</Color>
        <Color x:Key="SurfaceDarkColor">#1E293B</Color>
        <Color x:Key="ToolbarBgLight">#FFFFFF</Color>
        <Color x:Key="ToolbarBgDark">#1E293B</Color>
        <Color x:Key="SelectedColor">#DBEAFE</Color>
        <Color x:Key="SelectedDarkColor">#1E3A5F</Color>
        <Color x:Key="TextColorLight">#1E293B</Color>
        <Color x:Key="TextColorDark">#F1F5F9</Color>
        <Color x:Key="SecondaryTextLight">#64748B</Color>
        <Color x:Key="SecondaryTextDark">#94A3B8</Color>
        <Color x:Key="DividerLight">#CBD5E1</Color>
        <Color x:Key="DividerDark">#475569</Color>

        <Style TargetType="Button">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#0F172A, Dark=#E2E8F0}" />
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F1F5F9, Dark=#334155}" />
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderColor" Value="Transparent"/>
            <Setter Property="BorderWidth" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="MinimumHeightRequest" Value="40"/>
            <Setter Property="MinimumWidthRequest" Value="40"/>
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal"/>
                        <VisualState x:Name="Pressed">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#E2E8F0, Dark=#475569}"/>
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Disabled">
                            <VisualState.Setters>
                                <Setter Property="Opacity" Value="0.45"/>
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>
        
        <Style x:Key="ColorButton" TargetType="Button">
            <Setter Property="WidthRequest" Value="28"/>
            <Setter Property="HeightRequest" Value="28"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderWidth" Value="2"/>
            <Setter Property="BorderColor" Value="Transparent"/>
        </Style>

        <Style x:Key="ToolButtonImg" TargetType="ImageButton">
            <Setter Property="WidthRequest" Value="44"/>
            <Setter Property="HeightRequest" Value="44"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BackgroundColor" Value="Transparent"/>
            <Setter Property="TintColor" Value="{AppThemeBinding Light=#1E293B, Dark=#F1F5F9}"/>
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal"/>
                        <VisualState x:Name="Pressed">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"/>
                                <Setter Property="TintColor" Value="{AppThemeBinding Light=#0F172A, Dark=#FFFFFF}"/>
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Disabled">
                            <VisualState.Setters>
                                <Setter Property="Opacity" Value="0.45"/>
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>

        <Style x:Key="ToolButtonSelectedImg" TargetType="ImageButton">
            <Setter Property="WidthRequest" Value="44"/>
            <Setter Property="HeightRequest" Value="44"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#DBEAFE, Dark=#334155}"/>
            <Setter Property="TintColor" Value="{AppThemeBinding Light=#2563EB, Dark=#93C5FD}"/>
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal"/>
                        <VisualState x:Name="Pressed">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#BFDBFE, Dark=#1E3A5F}"/>
                                <Setter Property="TintColor" Value="{AppThemeBinding Light=#1D4ED8, Dark=#BFDBFE}"/>
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Disabled">
                            <VisualState.Setters>
                                <Setter Property="Opacity" Value="0.45"/>
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>

        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="WidthRequest" Value="44"/>
            <Setter Property="HeightRequest" Value="44"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BackgroundColor" Value="Transparent"/>
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#1E293B, Dark=#F1F5F9}"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <Style x:Key="ToolButtonSelected" TargetType="Button">
            <Setter Property="WidthRequest" Value="44"/>
            <Setter Property="HeightRequest" Value="44"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#DBEAFE, Dark=#334155}"/>
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#2563EB, Dark=#93C5FD}"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>
    </ContentPage.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- PDF and Drawing Container -->
        <Grid x:Name="EditorHost" Grid.Row="0"/>

        <!-- Home Panel -->
        <Border x:Name="HomePanel"
                Grid.RowSpan="2"
                IsVisible="True"
                Margin="16,24,16,16"
                BackgroundColor="{AppThemeBinding Light={StaticResource ToolbarBgLight}, Dark={StaticResource ToolbarBgDark}}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 16"
                Padding="16">
            <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="12">
                <VerticalStackLayout Grid.Row="0" Spacing="2">
                    <Label Text="FlowNote"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource TextColorLight}, Dark={StaticResource TextColorDark}}"/>
                    <Label Text="Import PDF and open an existing note"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}"/>
                </VerticalStackLayout>

                <HorizontalStackLayout Grid.Row="1" Spacing="8">
                    <Button Text="Import PDF" Clicked="OnHomeImportLocalClicked"/>
                    <Button Text="Refresh" Clicked="OnHomeRefreshClicked"/>
                    <Button Text="Settings" Clicked="OnMenuClicked"/>
                </HorizontalStackLayout>

                <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Entry x:Name="HomeUrlEntry" Placeholder="Paste PDF URL"/>
                    <Button Grid.Column="1" Text="Import URL" Clicked="OnHomeImportUrlClicked"/>
                </Grid>

                <ScrollView Grid.Row="3">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Imported PDFs" FontAttributes="Bold" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}"/>
                        <VerticalStackLayout x:Name="HomeNotesList" Spacing="6"/>
                    </VerticalStackLayout>
                </ScrollView>
            </Grid>
        </Border>

        <!-- Top Bar -->
        <Border x:Name="TopBarPanel"
                Grid.Row="0"
                IsVisible="False"
                VerticalOptions="Start"
                HorizontalOptions="Center"
                Margin="16,12,16,0"
                BackgroundColor="{AppThemeBinding Light={StaticResource ToolbarBgLight}, Dark={StaticResource ToolbarBgDark}}"
                StrokeThickness="0"
                Padding="8,4"
                Opacity="0.95"
                StrokeShape="RoundRectangle 12">
            <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto" ColumnSpacing="4">
                <!-- Home -->
                <ImageButton Grid.Column="0" Style="{StaticResource ToolButtonImg}" Source="icon_home.svg" Clicked="OnHomeClicked"/>

                <!-- Menu -->
                <ImageButton Grid.Column="1" Style="{StaticResource ToolButtonImg}" Source="icon_menu.svg" Clicked="OnMenuClicked"/>

                <!-- Page Navigation -->
                <ImageButton Grid.Column="2" Style="{StaticResource ToolButtonImg}" Source="icon_arrow_left.svg" Clicked="OnPrevPageClicked" x:Name="PrevPageButton"/>
                <Label Grid.Column="3" x:Name="PageInfoLabel"
                       Text="1/1"
                       FontSize="13"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource TextColorLight}, Dark={StaticResource TextColorDark}}"/>
                <ImageButton Grid.Column="4" Style="{StaticResource ToolButtonImg}" Source="icon_arrow_right.svg" Clicked="OnNextPageClicked" x:Name="NextPageButton"/>

                <!-- Draw Toggle -->
                <ImageButton Grid.Column="5" x:Name="DrawingToggleButton" Style="{StaticResource ToolButtonSelectedImg}" Source="icon_pencil.svg" Clicked="OnDrawingToggleClicked"/>
            </Grid>
        </Border>

        <!-- Drawing Toolbar (Bottom) -->
        <Border x:Name="DrawingToolbarPanel"
                Grid.Row="1"
                IsVisible="False"
                Margin="0,0,0,0"
                BackgroundColor="{AppThemeBinding Light={StaticResource ToolbarBgLight}, Dark={StaticResource ToolbarBgDark}}"
                Padding="12,8">
            <Grid RowDefinitions="Auto,Auto">
                <!-- Tools Row -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto,*,Auto,Auto,Auto,Auto" ColumnSpacing="4" Margin="0,0,0,8">
                    <!-- Pen Mode Toggle -->
                    <ImageButton Grid.Column="0" x:Name="PenModeButton" Style="{StaticResource ToolButtonSelectedImg}" Source="icon_pencil.svg" Clicked="OnPenModeClicked" ToolTipProperties.Text="Pen Mode"/>
                    
                    <!-- Highlighter -->
                    <ImageButton Grid.Column="1" x:Name="HighlighterButton" Style="{StaticResource ToolButtonImg}" Source="icon_brush.svg" Clicked="OnHighlighterClicked"/>
                    
                    <!-- Eraser -->
                    <ImageButton Grid.Column="2" x:Name="EraserButton" Style="{StaticResource ToolButtonImg}" Source="icon_eraser.svg" Clicked="OnEraserClicked"/>

                    <BoxView Grid.Column="3" WidthRequest="1" BackgroundColor="{AppThemeBinding Light={StaticResource DividerLight}, Dark={StaticResource DividerDark}}" Margin="8,8"/>

                    <!-- Undo -->
                    <ImageButton Grid.Column="4" x:Name="UndoButton" Style="{StaticResource ToolButtonImg}" Source="icon_arrow_back_up.svg" Clicked="OnUndoClicked"/>
                    
                    <!-- Redo -->
                    <ImageButton Grid.Column="5" x:Name="RedoButton" Style="{StaticResource ToolButtonImg}" Source="icon_arrow_forward_up.svg" Clicked="OnRedoClicked"/>
                    
                    <!-- Clear -->
                    <ImageButton Grid.Column="6" x:Name="ClearButton2" Style="{StaticResource ToolButtonImg}" Source="icon_trash.svg" Clicked="OnClearClicked"/>
                </Grid>

                <!-- Color & Size Row -->
                <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                    <!-- Color Picker -->
                    <StackLayout Grid.Column="0" Orientation="Horizontal" Spacing="6">
                        <Button x:Name="ColorBlack" Style="{StaticResource ColorButton}" BackgroundColor="#000000" Clicked="OnColorBlackClicked" WidthRequest="24" HeightRequest="24"/>
                        <Button x:Name="ColorRed" Style="{StaticResource ColorButton}" BackgroundColor="#EF4444" Clicked="OnColorRedClicked" WidthRequest="24" HeightRequest="24"/>
                        <Button x:Name="ColorBlue" Style="{StaticResource ColorButton}" BackgroundColor="#3B82F6" Clicked="OnColorBlueClicked" WidthRequest="24" HeightRequest="24"/>
                        <Button x:Name="ColorGreen" Style="{StaticResource ColorButton}" BackgroundColor="#22C55E" Clicked="OnColorGreenClicked" WidthRequest="24" HeightRequest="24"/>
                        <Button x:Name="ColorOrange" Style="{StaticResource ColorButton}" BackgroundColor="#F97316" Clicked="OnColorOrangeClicked" WidthRequest="24" HeightRequest="24"/>
                        <Button x:Name="ColorWhite" Style="{StaticResource ColorButton}" BackgroundColor="#FFFFFF" BorderColor="#CBD5E1" BorderWidth="1" Clicked="OnColorWhiteClicked" WidthRequest="24" HeightRequest="24"/>
                    </StackLayout>

                    <!-- Stroke Width -->
                    <StackLayout Grid.Column="1" Orientation="Horizontal" Spacing="6" HorizontalOptions="Center">
                        <Label Text="Size" VerticalOptions="Center" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource TextColorLight}, Dark={StaticResource TextColorDark}}"/>
                        <Slider x:Name="StrokeWidthSlider"
                                WidthRequest="120"
                                Minimum="1"
                                Maximum="20"
                                Value="3"
                                ValueChanged="OnStrokeWidthChanged"
                                VerticalOptions="Center"/>
                        <Label x:Name="StrokeWidthLabel"
                               Text="3"
                               FontSize="12"
                               WidthRequest="24"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource TextColorLight}, Dark={StaticResource TextColorDark}}"/>
                    </StackLayout>

                    <!-- Layer & Close -->
                    <StackLayout Grid.Column="2" Orientation="Horizontal" Spacing="4">
                        <ImageButton Style="{StaticResource ToolButtonImg}" Source="icon_layers_selected.svg" Clicked="OnLayerToggleClicked" ToolTipProperties.Text="Layers"/>
                        <ImageButton Style="{StaticResource ToolButtonImg}" Source="icon_x.svg" Clicked="OnDrawingToolbarCloseClicked"/>
                    </StackLayout>
                </Grid>
            </Grid>
        </Border>

        <!-- Layer Panel -->
        <Border x:Name="LayerPanel"
                Grid.Row="0"
                IsVisible="False"
                VerticalOptions="Fill"
                HorizontalOptions="End"
                WidthRequest="200"
                Margin="0,60,12,100"
                BackgroundColor="{AppThemeBinding Light={StaticResource ToolbarBgLight}, Dark={StaticResource ToolbarBgDark}}"
                StrokeThickness="0"
                Opacity="0.95"
                Padding="12">
            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
                <Label Grid.Row="0" Text="Layers" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource TextColorLight}, Dark={StaticResource TextColorDark}}"/>

                <ScrollView Grid.Row="1">
                    <VerticalStackLayout x:Name="LayerList" Spacing="4"/>
                </ScrollView>

                <StackLayout Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalOptions="Center">
                    <ImageButton Style="{StaticResource ToolButtonImg}" WidthRequest="40" HeightRequest="40" Source="icon_plus.svg" Clicked="OnAddLayerClicked"/>
                    <ImageButton Style="{StaticResource ToolButtonImg}" WidthRequest="40" HeightRequest="40" Source="icon_minus.svg" Clicked="OnDeleteLayerClicked"/>
                </StackLayout>
            </Grid>
        </Border>

        <!-- Settings Panel -->
        <Border x:Name="SettingsPanel"
                Grid.Row="0"
                IsVisible="False"
                VerticalOptions="Fill"
                HorizontalOptions="Start"
                WidthRequest="280"
                Margin="0,60,0,100"
                BackgroundColor="{AppThemeBinding Light={StaticResource ToolbarBgLight}, Dark={StaticResource ToolbarBgDark}}"
                StrokeThickness="0"
                Opacity="0.95"
                Padding="16">
            <ScrollView>
                <VerticalStackLayout Spacing="16">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Label Text="Settings" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource TextColorLight}, Dark={StaticResource TextColorDark}}"/>
                        <ImageButton Grid.Column="1" Style="{StaticResource ToolButtonImg}" WidthRequest="30" HeightRequest="30" Source="icon_x.svg" Clicked="OnSettingsCloseClicked"/>
                    </Grid>

                    <!-- File Section -->
                    <Label Text="File" FontAttributes="Bold" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}"/>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Entry x:Name="UrlEntry" Placeholder="PDF URL"/>
                        <Button Grid.Column="1" x:Name="LoadUrlButton" Text="Load" Clicked="OnLoadUrlClicked"/>
                    </Grid>

                    <HorizontalStackLayout Spacing="8">
                        <Button x:Name="LoadSampleButton" Text="Sample" Clicked="OnLoadSampleClicked"/>
                        <Button x:Name="LocalFileButton" Text="Open" Clicked="OnPickFileClicked"/>
                    </HorizontalStackLayout>

                    <!-- Workspace Section -->
                    <Label Text="Workspace" FontAttributes="Bold" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}"/>

                    <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="8">
                        <Button Grid.Column="0" Text="Root" Clicked="OnWorkspaceRootClicked"/>
                        <Button Grid.Column="1" Text="Up" Clicked="OnWorkspaceUpClicked"/>
                        <Entry Grid.Column="2" x:Name="WorkspaceFolderEntry" Placeholder="/"/>
                        <Button Grid.Column="3" Text="Go" Clicked="OnWorkspaceOpenFolderClicked"/>
                    </Grid>

                    <HorizontalStackLayout Spacing="8">
                        <Entry x:Name="WorkspaceNewFolderEntry" Placeholder="New folder" HorizontalOptions="FillAndExpand"/>
                        <Button Text="Create" Clicked="OnWorkspaceCreateFolderClicked"/>
                        <Button Text="Refresh" Clicked="OnWorkspaceRefreshClicked"/>
                    </HorizontalStackLayout>

                    <Label Text="Recent" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}"/>
                    <VerticalStackLayout x:Name="RecentNotesList" Spacing="4"/>

                    <Label Text="Folders" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}"/>
                    <VerticalStackLayout x:Name="WorkspaceFolderList" Spacing="4"/>

                    <Label Text="Notes" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}"/>
                    <VerticalStackLayout x:Name="WorkspaceNoteList" Spacing="4"/>

                    <!-- Search Section -->
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Entry x:Name="SearchEntry" Grid.Column="0" Placeholder="Search"/>
                        <ImageButton x:Name="SearchButton" Grid.Column="1" Style="{StaticResource ToolButtonImg}" WidthRequest="40" HeightRequest="40" Source="icon_search.svg" Clicked="OnSearchClicked"/>
                    </Grid>

                    <HorizontalStackLayout Spacing="8">
                        <ImageButton x:Name="SearchPrevButton" Style="{StaticResource ToolButtonImg}" WidthRequest="40" HeightRequest="40" Source="icon_arrow_left.svg" Clicked="OnSearchPrevClicked"/>
                        <ImageButton x:Name="SearchNextButton" Style="{StaticResource ToolButtonImg}" WidthRequest="40" HeightRequest="40" Source="icon_arrow_right.svg" Clicked="OnSearchNextClicked"/>
                        <Label x:Name="SearchStatusLabel" Text="" VerticalOptions="Center" FontSize="11"/>
                    </HorizontalStackLayout>

                    <!-- View Section -->
                    <Label Text="View" FontAttributes="Bold" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}"/>

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <Picker x:Name="DisplayModePicker" Title="Mode"/>
                        <Picker Grid.Column="1" x:Name="OrientationPicker" Title="Direction"/>
                        <Picker Grid.Column="2" x:Name="FitPolicyPicker" Title="Fit"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Slider x:Name="ZoomSlider" Minimum="0.5" Maximum="4" Value="1" ValueChanged="OnZoomSliderValueChanged"/>
                        <Label Grid.Column="1" x:Name="ZoomValueLabel" Text="1.0x" WidthRequest="50" VerticalOptions="Center"/>
                    </Grid>

                    <!-- Tools Section -->
                    <Label Text="Tools" FontAttributes="Bold" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}"/>

                    <FlexLayout Direction="Row" Wrap="Wrap">
                        <StackLayout Orientation="Horizontal" Margin="0,0,16,6">
                            <Label Text="Zoom" VerticalOptions="Center" FontSize="12"/>
                            <Switch x:Name="EnableZoomSwitch" IsToggled="True" Toggled="OnEnableZoomToggled"/>
                        </StackLayout>
                        <StackLayout Orientation="Horizontal" Margin="0,0,16,6">
                            <Label Text="Swipe" VerticalOptions="Center" FontSize="12"/>
                            <Switch x:Name="EnableSwipeSwitch" IsToggled="True" Toggled="OnEnableSwipeToggled"/>
                        </StackLayout>
                        <StackLayout Orientation="Horizontal" Margin="0,0,16,6">
                            <Label Text="Links" VerticalOptions="Center" FontSize="12"/>
                            <Switch x:Name="EnableLinkSwitch" IsToggled="True" Toggled="OnEnableLinkToggled"/>
                        </StackLayout>
                        <StackLayout Orientation="Horizontal" Margin="0,0,16,6">
                            <Label Text="Finger Draw" VerticalOptions="Center" FontSize="12"/>
                            <Switch x:Name="EnableFingerDrawSwitch" IsToggled="False" Toggled="OnFingerDrawToggled"/>
                        </StackLayout>
                    </FlexLayout>

                    <!-- Language -->
                    <Label Text="Language" FontAttributes="Bold" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}"/>
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="English" Clicked="OnLangEnClicked"/>
                        <Button Text="中文" Clicked="OnLangZhClicked"/>
                    </HorizontalStackLayout>

                    <!-- Status -->
                    <Label x:Name="EventInfoLabel" Text="Ready" FontSize="11" TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}"/>
                </VerticalStackLayout>
            </ScrollView>
        </Border>

        <!-- Status Toast -->
        <Border x:Name="StatusToast"
                Grid.Row="0"
                VerticalOptions="End"
                HorizontalOptions="Center"
                Margin="0,0,0,80"
                BackgroundColor="{AppThemeBinding Light=#1E293B, Dark=#1E293B}"
                Padding="16,8"
                Opacity="0"
                IsVisible="False">
            <Label x:Name="StatusLabel" Text="" FontSize="12" TextColor="White"/>
        </Border>
    </Grid>
</ContentPage>
