<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="FlowNoteMauiApp.Views.Shared.DrawerOverlayView"
    BackgroundColor="Transparent"
>
    <ContentView.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary
                    Source="/Resources/Styles/MainPageStyles.xaml"
                />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ContentView.Resources>
<Grid x:Name="HomeDrawerOverlay" IsVisible="False" BackgroundColor="#55000000">
    <Grid ColumnDefinitions="292,*">
        <Border
                Grid.Column="0"
                Margin="10,8,0,8"
                Padding="12,10,12,10"
                Style="{StaticResource DrawerOverlayPanel}"
            >
            <ScrollView>
                <VerticalStackLayout Spacing="6">
                    <Grid
                            Padding="1,1,1,4"
                            ColumnDefinitions="Auto,*,Auto"
                            ColumnSpacing="8"
                        >
                        <Border
                                WidthRequest="34"
                                HeightRequest="34"
                                StrokeShape="RoundRectangle 17"
                                Stroke="{AppThemeBinding Light=#D3DAE6, Dark=#4B607A}"
                                StrokeThickness="1"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A3A50}"
                            >
                            <Image
                                    Source="icon_file.png"
                                    WidthRequest="13"
                                    HeightRequest="13"
                                    VerticalOptions="Center"
                                    HorizontalOptions="Center"
                                    Opacity="0.78"
                                />
                        </Border>
                        <VerticalStackLayout
                                Grid.Column="1"
                                Spacing="1"
                                VerticalOptions="Center"
                            >
                            <Label
                                    x:Name="DrawerAuthLabel"
                                    Text="登录/注册"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="14.5"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                />
                            <Label
                                    x:Name="DrawerSyncHintLabel"
                                    Text="同步你的学习进度"
                                    FontSize="10.5"
                                    TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                                />
                        </VerticalStackLayout>
                        <ImageButton
                                x:Name="DrawerHeaderCloseButton"
                                Grid.Column="2"
                                Style="{StaticResource HeaderIconButton}"
                                Source="icon_x.png"
                                WidthRequest="24"
                                HeightRequest="24"
                                MinimumWidthRequest="24"
                                MinimumHeightRequest="24"
                            />
                    </Grid>

                    <Border Style="{StaticResource DrawerSectionCard}">
                        <VerticalStackLayout Spacing="2">
                            <Button
                                    x:Name="DrawerAllDocsButton"
                                    Style="{StaticResource DrawerItemButton}"
                                    Text="所有文档"
                                    ImageSource="icon_file.png"
                                />
                            <BoxView
                                    HeightRequest="0.5"
                                    Color="{AppThemeBinding Light=#EEF2F7, Dark=#374D66}"
                                />
                            <Button
                                    x:Name="DrawerRecentButton"
                                    Style="{StaticResource DrawerItemButton}"
                                    Text="最近使用"
                                    ImageSource="home_bell.png"
                                />
                            <BoxView
                                    HeightRequest="0.5"
                                    Color="{AppThemeBinding Light=#EEF2F7, Dark=#374D66}"
                                />
                            <Button
                                    x:Name="DrawerFavoriteButton"
                                    Style="{StaticResource DrawerItemButton}"
                                    Text="我的收藏"
                                    ImageSource="home_done.png"
                                />
                            <BoxView
                                    HeightRequest="0.5"
                                    Color="{AppThemeBinding Light=#EEF2F7, Dark=#374D66}"
                                />
                            <Button
                                    x:Name="DrawerTrashButton"
                                    Style="{StaticResource DrawerItemButton}"
                                    Text="回收站"
                                    ImageSource="icon_trash.png"
                                />
                        </VerticalStackLayout>
                    </Border>

                    <Label
                            x:Name="DrawerTagsTitleLabel"
                            Text="我的标签"
                            Style="{StaticResource DrawerSectionTitleLabel}"
                        />
                    <Border Style="{StaticResource DrawerSectionCard}">
                        <VerticalStackLayout Spacing="2">
                            <Button
                                    x:Name="DrawerEditTagsButton"
                                    Style="{StaticResource DrawerItemButton}"
                                    Text="编辑标签"
                                    ImageSource="icon_pencil.png"
                                />
                            <BoxView
                                    HeightRequest="0.5"
                                    Color="{AppThemeBinding Light=#EEF2F7, Dark=#374D66}"
                                />
                            <Button
                                    x:Name="DrawerCreateTagButton"
                                    Style="{StaticResource DrawerItemButton}"
                                    Text="创建新标签"
                                    ImageSource="icon_plus.png"
                                />
                        </VerticalStackLayout>
                    </Border>

                    <Label
                            x:Name="DrawerAppsTitleLabel"
                            Text="我的应用"
                            Style="{StaticResource DrawerSectionTitleLabel}"
                        />
                    <Border Style="{StaticResource DrawerSectionCard}">
                        <VerticalStackLayout Spacing="2">
                            <Button
                                    x:Name="DrawerHelpButton"
                                    Style="{StaticResource DrawerItemButton}"
                                    Text="帮助中心"
                                    ImageSource="icon_search.png"
                                />
                            <BoxView
                                    HeightRequest="0.5"
                                    Color="{AppThemeBinding Light=#EEF2F7, Dark=#374D66}"
                                />
                            <Button
                                    x:Name="DrawerAboutButton"
                                    Style="{StaticResource DrawerItemButton}"
                                    Text="关于我们"
                                    ImageSource="icon_settings.png"
                                />
                            <BoxView
                                    HeightRequest="0.5"
                                    Color="{AppThemeBinding Light=#EEF2F7, Dark=#374D66}"
                                />
                            <Button
                                    x:Name="DrawerDiscountButton"
                                    Style="{StaticResource DrawerItemButton}"
                                    Text="获取折扣"
                                    ImageSource="home_done.png"
                                />
                        </VerticalStackLayout>
                    </Border>

                    <Border
                            Margin="0,6,0,0"
                            Padding="10,8"
                            BackgroundColor="{AppThemeBinding Light=#F4F6FA, Dark=#2C415A}"
                            Stroke="{AppThemeBinding Light=#E3E8F1, Dark=#415C79}"
                            StrokeThickness="0.8"
                            StrokeShape="RoundRectangle 12"
                        >
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <Image
                                    Source="icon_file.png"
                                    WidthRequest="13"
                                    HeightRequest="13"
                                    Opacity="0.66"
                                    VerticalOptions="Center"
                                />
                            <Label
                                    x:Name="DrawerPromoLabel"
                                    Grid.Column="1"
                                    Text="注册即领免费试用\n解锁全功能笔记工作流"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="11.5"
                                    LineHeight="1.2"
                                    TextColor="{AppThemeBinding Light=#395070, Dark=#D7E6FA}"
                                />
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>
        </Border>

        <BoxView
                Grid.Column="1"
                Color="Transparent"
                BackgroundColor="Transparent"
            >
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer x:Name="DrawerBackdropTapGesture" />
            </BoxView.GestureRecognizers>
        </BoxView>
    </Grid>
</Grid>
</ContentView>
