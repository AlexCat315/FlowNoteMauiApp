<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="FlowNoteMauiApp.Views.Shared.DrawerOverlayView"
    BackgroundColor="Transparent"
>
    <ContentView.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary
                    Source="/Resources/Styles/MainPageStyles.xaml"
                />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ContentView.Resources>
<Grid x:Name="HomeDrawerOverlay" IsVisible="False" BackgroundColor="#660F1B2D">
    <Grid ColumnDefinitions="336,*">
        <Border
                Grid.Column="0"
                Margin="14,12,0,12"
                Padding="16,14,16,16"
                Style="{StaticResource DrawerOverlayPanel}"
            >
            <ScrollView>
                <VerticalStackLayout Spacing="10">
                    <Grid
                            Padding="2,2,2,8"
                            ColumnDefinitions="Auto,*,Auto"
                            ColumnSpacing="12"
                        >
                        <Border
                                WidthRequest="44"
                                HeightRequest="44"
                                StrokeShape="RoundRectangle 22"
                                Stroke="{AppThemeBinding Light=#C8D5E8, Dark=#4D6583}"
                                StrokeThickness="1"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A3D58}"
                            >
                            <Image
                                    Source="icon_file.png"
                                    WidthRequest="16"
                                    HeightRequest="16"
                                    VerticalOptions="Center"
                                    HorizontalOptions="Center"
                                    Opacity="0.88"
                                />
                        </Border>
                        <VerticalStackLayout
                                Grid.Column="1"
                                Spacing="2"
                                VerticalOptions="Center"
                            >
                            <Label
                                    x:Name="DrawerAuthLabel"
                                    Text="登录/注册"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="17"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                />
                            <Label
                                    x:Name="DrawerSyncHintLabel"
                                    Text="同步你的学习进度"
                                    FontSize="12.5"
                                    TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                                />
                        </VerticalStackLayout>
                        <ImageButton
                                x:Name="DrawerHeaderCloseButton"
                                Grid.Column="2"
                                Style="{StaticResource HeaderIconButton}"
                                Source="icon_x.png"
                                WidthRequest="30"
                                HeightRequest="30"
                                MinimumWidthRequest="30"
                                MinimumHeightRequest="30"
                            />
                    </Grid>

                    <Border Style="{StaticResource DrawerSectionCard}">
                        <VerticalStackLayout Spacing="2">
                            <Button
                                    x:Name="DrawerAllDocsButton"
                                    Style="{StaticResource DrawerItemButton}"
                                    Text="所有文档"
                                    ImageSource="icon_file.png"
                                />
                            <Button
                                    x:Name="DrawerRecentButton"
                                    Style="{StaticResource DrawerItemButton}"
                                    Text="最近使用"
                                    ImageSource="home_bell.png"
                                />
                            <Button
                                    x:Name="DrawerFavoriteButton"
                                    Style="{StaticResource DrawerItemButton}"
                                    Text="我的收藏"
                                    ImageSource="home_done.png"
                                />
                            <Button
                                    x:Name="DrawerTrashButton"
                                    Style="{StaticResource DrawerItemButton}"
                                    Text="回收站"
                                    ImageSource="icon_trash.png"
                                />
                        </VerticalStackLayout>
                    </Border>

                    <Label
                            x:Name="DrawerTagsTitleLabel"
                            Text="我的标签"
                            Style="{StaticResource DrawerSectionTitleLabel}"
                        />
                    <Border Style="{StaticResource DrawerSectionCard}">
                        <VerticalStackLayout Spacing="2">
                            <Button
                                    x:Name="DrawerEditTagsButton"
                                    Style="{StaticResource DrawerItemButton}"
                                    Text="编辑标签"
                                    ImageSource="icon_pencil.png"
                                />
                            <Button
                                    x:Name="DrawerCreateTagButton"
                                    Style="{StaticResource DrawerItemButton}"
                                    Text="创建新标签"
                                    ImageSource="icon_plus.png"
                                />
                        </VerticalStackLayout>
                    </Border>

                    <Label
                            x:Name="DrawerAppsTitleLabel"
                            Text="我的应用"
                            Style="{StaticResource DrawerSectionTitleLabel}"
                        />
                    <Border Style="{StaticResource DrawerSectionCard}">
                        <VerticalStackLayout Spacing="2">
                            <Button
                                    x:Name="DrawerHelpButton"
                                    Style="{StaticResource DrawerItemButton}"
                                    Text="帮助中心"
                                    ImageSource="icon_search.png"
                                />
                            <Button
                                    x:Name="DrawerAboutButton"
                                    Style="{StaticResource DrawerItemButton}"
                                    Text="关于我们"
                                    ImageSource="icon_settings.png"
                                />
                            <Button
                                    x:Name="DrawerDiscountButton"
                                    Style="{StaticResource DrawerItemButton}"
                                    Text="获取折扣"
                                    ImageSource="home_done.png"
                                />
                        </VerticalStackLayout>
                    </Border>

                    <Border
                            Margin="0,8,0,0"
                            Padding="14,12"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 16"
                        >
                        <Border.Background>
                            <LinearGradientBrush
                                    StartPoint="0,0"
                                    EndPoint="1,1"
                                >
                                <GradientStop Color="#4A90E2" Offset="0" />
                                <GradientStop Color="#6A7FF0" Offset="0.6" />
                                <GradientStop Color="#57B8E5" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <Image
                                    Source="icon_file.png"
                                    WidthRequest="16"
                                    HeightRequest="16"
                                    Opacity="0.9"
                                    VerticalOptions="Center"
                                />
                            <Label
                                    x:Name="DrawerPromoLabel"
                                    Grid.Column="1"
                                    Text="注册即领免费试用\n解锁全功能笔记工作流"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="13"
                                    LineHeight="1.2"
                                    TextColor="White"
                                />
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>
        </Border>

        <BoxView
                Grid.Column="1"
                Color="Transparent"
                BackgroundColor="Transparent"
            >
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer x:Name="DrawerBackdropTapGesture" />
            </BoxView.GestureRecognizers>
        </BoxView>
    </Grid>
</Grid>
</ContentView>
