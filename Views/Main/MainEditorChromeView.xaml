<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="FlowNoteMauiApp.Views.Main.MainEditorChromeView"
>
    <ContentView.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary
                    Source="/Resources/Styles/MainPageStyles.xaml"
                />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ContentView.Resources>
    <Grid InputTransparent="True" CascadeInputTransparent="False">
        <Border
            x:Name="TopBarPanel"
            IsVisible="False"
            InputTransparent="False"
            HorizontalOptions="Fill"
            VerticalOptions="Start"
            Margin="0"
            Padding="8,2,8,2"
            BackgroundColor="{AppThemeBinding Light=#F7F8FB, Dark=#162334}"
            Stroke="Transparent"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 0"
            Opacity="0.995"
        >
            <Grid RowDefinitions="Auto,Auto,1" RowSpacing="2">
                <Grid
                    Grid.Row="0"
                    ColumnDefinitions="Auto,*,Auto"
                    ColumnSpacing="8"
                    HeightRequest="34"
                >
                    <Border
                        Grid.Column="0"
                        Padding="1"
                        BackgroundColor="{AppThemeBinding Light=#EEF1F7, Dark=#1F2E43}"
                        Stroke="Transparent"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 9"
                    >
                        <ImageButton
                            x:Name="TopHomeButton"
                            Style="{StaticResource FlatTopIconButton}"
                            WidthRequest="24"
                            HeightRequest="24"
                            MinimumWidthRequest="24"
                            MinimumHeightRequest="24"
                            Padding="3"
                            Source="icon_arrow_left.png"
                        />
                    </Border>

                    <ScrollView
                        Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Never"
                    >
                        <HorizontalStackLayout
                            x:Name="EditorTabsHost"
                            Spacing="5"
                            VerticalOptions="Center"
                        />
                    </ScrollView>

                    <HorizontalStackLayout
                        Grid.Column="2"
                        Spacing="2"
                        VerticalOptions="Center"
                    >
                        <ImageButton
                            x:Name="TopImportButton"
                            Style="{StaticResource FlatTopIconButton}"
                            WidthRequest="24"
                            HeightRequest="24"
                            MinimumWidthRequest="24"
                            MinimumHeightRequest="24"
                            Padding="3"
                            TintColor="{AppThemeBinding Light=#1F2937, Dark=#0B1220}"
                            Source="icon_plus.png"
                        />
                        <ImageButton
                            x:Name="TopSearchButton"
                            Style="{StaticResource FlatTopIconButton}"
                            WidthRequest="24"
                            HeightRequest="24"
                            MinimumWidthRequest="24"
                            MinimumHeightRequest="24"
                            Padding="3"
                            TintColor="{AppThemeBinding Light=#1F2937, Dark=#0B1220}"
                            Source="icon_search.png"
                        />
                        <ImageButton
                            x:Name="TopModePenButton"
                            Style="{StaticResource FlatTopIconButton}"
                            WidthRequest="24"
                            HeightRequest="24"
                            MinimumWidthRequest="24"
                            MinimumHeightRequest="24"
                            Padding="3"
                            TintColor="{AppThemeBinding Light=#1F2937, Dark=#0B1220}"
                            Source="icon_stylus_mode.png"
                        />
                        <ImageButton
                            x:Name="TopSettingsButton"
                            Style="{StaticResource FlatTopIconButton}"
                            WidthRequest="24"
                            HeightRequest="24"
                            MinimumWidthRequest="24"
                            MinimumHeightRequest="24"
                            Padding="3"
                            TintColor="{AppThemeBinding Light=#1F2937, Dark=#0B1220}"
                            Source="icon_settings.png"
                        />
                        <ImageButton
                            x:Name="TopThumbnailButton"
                            Style="{StaticResource FlatTopIconButton}"
                            WidthRequest="24"
                            HeightRequest="24"
                            MinimumWidthRequest="24"
                            MinimumHeightRequest="24"
                            Padding="3"
                            TintColor="{AppThemeBinding Light=#1F2937, Dark=#0B1220}"
                            Source="icon_thumbnail.png"
                        />
                    </HorizontalStackLayout>
                </Grid>

                <ScrollView
                    Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalScrollBarVisibility="Never"
                >
                    <HorizontalStackLayout Spacing="6" Padding="0,1,0,1">
                        <Border
                            Padding="2,1"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1D2E45}"
                            Stroke="Transparent"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 8"
                        >
                            <HorizontalStackLayout Spacing="2">
                                <ImageButton
                                    x:Name="UndoButton"
                                    Style="{StaticResource ToolbarToolIconButton}"
                                    Source="icon_arrow_back_up.png"
                                />
                                <ImageButton
                                    x:Name="RedoButton"
                                    Style="{StaticResource ToolbarToolIconButton}"
                                    Source="icon_arrow_forward_up.png"
                                />
                            </HorizontalStackLayout>
                        </Border>

                        <Border
                            Padding="2,1"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1D2E45}"
                            Stroke="Transparent"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 8"
                        >
                            <HorizontalStackLayout
                                x:Name="InkToolsHost"
                                Spacing="2"
                            >
                                <ImageButton
                                    x:Name="PenModeButton"
                                    Style="{StaticResource ToolbarToolIconButtonSelected}"
                                    Source="icon_ballpoint_pen.png"
                                />
                                <ImageButton
                                    x:Name="HighlighterButton"
                                    Style="{StaticResource ToolbarToolIconButton}"
                                    Source="icon_gelpen.png"
                                />
                                <ImageButton
                                    x:Name="PencilButton"
                                    Style="{StaticResource ToolbarToolIconButton}"
                                    Source="icon_pencil.png"
                                />
                                <ImageButton
                                    x:Name="MarkerButton"
                                    Style="{StaticResource ToolbarToolIconButton}"
                                    Source="icon_markpen.png"
                                />
                                <ImageButton
                                    x:Name="EraserButton"
                                    Style="{StaticResource ToolbarToolIconButton}"
                                    Source="icon_eraser.png"
                                />
                                <ImageButton
                                    x:Name="ClearButton2"
                                    Style="{StaticResource ToolbarToolIconButton}"
                                    Source="icon_trash.png"
                                />
                                <ImageButton
                                    x:Name="TopInlineLayerButton"
                                    Style="{StaticResource ToolbarToolIconButton}"
                                    Source="icon_layers_selected.png"
                                />
                            </HorizontalStackLayout>
                        </Border>

                        <Border
                            Padding="2,1"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1D2E45}"
                            Stroke="Transparent"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 8"
                        >
                            <HorizontalStackLayout Spacing="2">
                                <ImageButton
                                    x:Name="TextToolButton"
                                    Style="{StaticResource ToolbarToolIconButton}"
                                    Source="icon_text.png"
                                />
                                <ImageButton
                                    x:Name="ImageToolButton"
                                    Style="{StaticResource ToolbarToolIconButton}"
                                    Source="icon_image.png"
                                />
                                <ImageButton
                                    x:Name="ShapeToolButton"
                                    Style="{StaticResource ToolbarToolIconButton}"
                                    Source="icon_shape.png"
                                />
                            </HorizontalStackLayout>
                        </Border>

                        <Border
                            Padding="2,1"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1D2E45}"
                            Stroke="Transparent"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 8"
                        >
                            <HorizontalStackLayout
                                Spacing="2"
                                VerticalOptions="Center"
                            >
                                <ImageButton
                                    x:Name="PrevPageButton"
                                    Style="{StaticResource ToolbarToolIconButton}"
                                    Source="icon_arrow_left.png"
                                />
                                <Border
                                    Padding="8,0"
                                    HeightRequest="28"
                                    VerticalOptions="Center"
                                    BackgroundColor="{AppThemeBinding Light=#F7F8FA, Dark=#2A3C55}"
                                    Stroke="Transparent"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8"
                                >
                                    <Label
                                        x:Name="PageInfoLabel"
                                        Text="Page: 1/1"
                                        VerticalOptions="Center"
                                        FontFamily="OpenSansSemibold"
                                        FontSize="12"
                                        TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                    />
                                </Border>
                                <ImageButton
                                    x:Name="NextPageButton"
                                    Style="{StaticResource ToolbarToolIconButton}"
                                    Source="icon_arrow_right.png"
                                />
                            </HorizontalStackLayout>
                        </Border>

                    </HorizontalStackLayout>
                </ScrollView>

                <BoxView
                    Grid.Row="2"
                    HeightRequest="1"
                    Color="{AppThemeBinding Light=#DCE2ED, Dark=#34475F}"
                />
            </Grid>
        </Border>

        <Border
            x:Name="DrawingToolbarPanel"
            IsVisible="False"
            ZIndex="36"
            InputTransparent="False"
            VerticalOptions="Start"
            HorizontalOptions="Start"
            Margin="0"
            WidthRequest="236"
            MaximumWidthRequest="248"
            Padding="0"
            Style="{StaticResource PanelCard}"
        >
            <VerticalStackLayout Spacing="0">
                <Grid
                    Padding="12,10"
                    ColumnDefinitions="*,Auto"
                    ColumnSpacing="6"
                >
                    <Label
                        x:Name="ToolSettingsTitleLabel"
                        Text="圆珠笔"
                        FontFamily="OpenSansSemibold"
                        FontSize="16"
                        HorizontalTextAlignment="Center"
                        VerticalOptions="Center"
                    />
                    <ImageButton
                        x:Name="DrawingToolbarCloseButton"
                        Grid.Column="1"
                        Style="{StaticResource ToolbarToolIconButton}"
                        Source="icon_x.png"
                    />
                </Grid>

                <BoxView
                    HeightRequest="1"
                    Color="{AppThemeBinding Light=#ECEFF4, Dark=#36475F}"
                />

                <VerticalStackLayout Padding="12,10" Spacing="10">
                    <VerticalStackLayout
                        x:Name="EraserModePanel"
                        IsVisible="False"
                        Spacing="10"
                    >
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                            <Button
                                x:Name="PixelEraserModeButton"
                                Text="像素擦除"
                                Style="{StaticResource InputModeItemButton}"
                                FontSize="12"
                            />
                            <Button
                                x:Name="StrokeEraserModeButton"
                                Grid.Column="1"
                                Text="整笔擦除"
                                Style="{StaticResource InputModeItemButton}"
                                FontSize="12"
                            />
                            <Button
                                x:Name="LassoEraserModeButton"
                                Grid.Column="2"
                                Text="圈选擦除"
                                Style="{StaticResource InputModeItemButton}"
                                FontSize="12"
                            />
                        </Grid>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Label
                            x:Name="DrawingPenWidthLabel"
                            Text="粗细"
                            FontFamily="OpenSansSemibold"
                            FontSize="13"
                            VerticalOptions="Center"
                        />
                        <Label
                            x:Name="StrokeWidthLabel"
                            Grid.Column="2"
                            Text="3.0mm"
                            FontSize="12"
                            VerticalOptions="Center"
                            HorizontalTextAlignment="End"
                            TextColor="{AppThemeBinding Light=#8A8F99, Dark=#A8B3C4}"
                        />
                    </Grid>

                    <Border
                        Padding="8"
                        BackgroundColor="{AppThemeBinding Light=#FAFBFD, Dark=#27384F}"
                        Stroke="{AppThemeBinding Light=#ECEEF3, Dark=#36465E}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                    >
                        <Slider
                            x:Name="StrokeWidthSlider"
                            Minimum="1"
                            Maximum="20"
                            Value="3"
                            VerticalOptions="Center"
                        />
                    </Border>

                    <VerticalStackLayout x:Name="PressurePanel" Spacing="8">
                        <Grid
                            ColumnDefinitions="Auto,*,Auto"
                            ColumnSpacing="10"
                        >
                            <Label
                                x:Name="PressureSensitivityTitleLabel"
                                Text="压感"
                                FontFamily="OpenSansSemibold"
                                FontSize="13"
                                VerticalOptions="Center"
                            />
                            <Label
                                x:Name="PressureValueLabel"
                                Grid.Column="2"
                                Text="100%"
                                FontSize="12"
                                VerticalOptions="Center"
                                HorizontalTextAlignment="End"
                                TextColor="{AppThemeBinding Light=#8A8F99, Dark=#A8B3C4}"
                            />
                        </Grid>
                        <Border
                            Padding="8"
                            BackgroundColor="{AppThemeBinding Light=#FAFBFD, Dark=#27384F}"
                            Stroke="{AppThemeBinding Light=#ECEEF3, Dark=#36465E}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12"
                        >
                            <Slider
                                x:Name="PressureSensitivitySlider"
                                Minimum="0.4"
                                Maximum="2.0"
                                Value="1.0"
                                VerticalOptions="Center"
                            />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout x:Name="ToolColorPanel" Spacing="10">
                        <Label
                            x:Name="ToolColorTitleLabel"
                            Text="颜色"
                            FontFamily="OpenSansSemibold"
                            FontSize="13"
                            VerticalOptions="Center"
                        />
                        <Border
                            Padding="8"
                            BackgroundColor="{AppThemeBinding Light=#FAFBFD, Dark=#27384F}"
                            Stroke="{AppThemeBinding Light=#ECEEF3, Dark=#36465E}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12"
                        >
                            <HorizontalStackLayout
                                Spacing="6"
                                VerticalOptions="Center"
                            >
                                <Button
                                    x:Name="ColorBlack"
                                    Style="{StaticResource ColorButton}"
                                    BackgroundColor="#111111"
                                />
                                <Button
                                    x:Name="ColorBlue"
                                    Style="{StaticResource ColorButton}"
                                    BackgroundColor="#2F74D0"
                                />
                                <Button
                                    x:Name="ColorRed"
                                    Style="{StaticResource ColorButton}"
                                    BackgroundColor="#E23B30"
                                />
                                <Button
                                    x:Name="ColorGreen"
                                    Style="{StaticResource ColorButton}"
                                    BackgroundColor="#2CC66D"
                                />
                                <Button
                                    x:Name="ColorOrange"
                                    Style="{StaticResource ColorButton}"
                                    BackgroundColor="#F4B100"
                                />
                                <Button
                                    x:Name="ColorWhite"
                                    Style="{StaticResource ColorButton}"
                                    BackgroundColor="#FFFFFF"
                                    BorderColor="#CBD5E1"
                                    BorderWidth="1"
                                />
                            </HorizontalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Border>

        <Border
            x:Name="ThumbnailPanel"
            IsVisible="False"
            ZIndex="37"
            InputTransparent="False"
            VerticalOptions="Start"
            HorizontalOptions="Start"
            WidthRequest="268"
            MaximumWidthRequest="286"
            Margin="0"
            Padding="10"
            Style="{StaticResource PanelCard}"
            BackgroundColor="{AppThemeBinding Light=#F7F9FC, Dark=#1E2E44}"
        >
            <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="8">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="6">
                    <Label
                        x:Name="ThumbnailTitleLabel"
                        Text="缩略图"
                        FontFamily="OpenSansSemibold"
                        FontSize="15"
                        VerticalOptions="Center"
                    />
                    <ImageButton
                        x:Name="ThumbnailCloseButton"
                        Grid.Column="1"
                        Style="{StaticResource ToolbarToolIconButton}"
                        Source="icon_x.png"
                    />
                </Grid>
                <Grid Grid.Row="1" ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <Switch
                        x:Name="ThumbnailOverlaySwitch"
                        IsToggled="True"
                        Scale="0.82"
                        VerticalOptions="Center"
                    />
                    <Label
                        x:Name="ThumbnailOverlayLabel"
                        Grid.Column="1"
                        Text="显示笔记层"
                        FontSize="12"
                        VerticalOptions="Center"
                        TextColor="{AppThemeBinding Light=#475569, Dark=#A8B4C8}"
                    />
                </Grid>
                <Border
                    Grid.Row="2"
                    Padding="6"
                    Stroke="{AppThemeBinding Light=#E4E9F2, Dark=#31465F}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#22344B}"
                >
                    <ScrollView>
                        <VerticalStackLayout
                            x:Name="ThumbnailList"
                            Spacing="6"
                        />
                    </ScrollView>
                </Border>
                <Label
                    x:Name="ThumbnailHintLabel"
                    Grid.Row="3"
                    Text="点击缩略项快速跳页"
                    FontSize="11"
                    HorizontalTextAlignment="Center"
                    TextColor="{AppThemeBinding Light=#7C8492, Dark=#A2B2C8}"
                />
            </Grid>
        </Border>

        <Border
            x:Name="InputModePanel"
            IsVisible="False"
            ZIndex="38"
            InputTransparent="False"
            VerticalOptions="Start"
            HorizontalOptions="Start"
            Margin="0"
            Padding="10"
            WidthRequest="248"
            MaximumWidthRequest="264"
            Style="{StaticResource PanelCard}"
        >
            <VerticalStackLayout Spacing="4">
                <Label
                    x:Name="InputModeTitleLabel"
                    Text="模式切换"
                    FontFamily="OpenSansSemibold"
                    FontSize="12"
                    TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}"
                />
                <Label
                    x:Name="InputModeHintLabel"
                    Text="手写: 笔写+手势导航 | 触控: 单指写双指移 | 阅读: 保留笔记仅浏览"
                    FontSize="10"
                    TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                    <Label
                        x:Name="InputModePenCheck"
                        Grid.Column="1"
                        VerticalOptions="Center"
                        Text="✓"
                        FontSize="14"
                        TextColor="{StaticResource PrimaryBlue}"
                    />
                    <Button
                        x:Name="InputModePenButton"
                        Grid.Column="0"
                        Style="{StaticResource InputModeItemButton}"
                        ImageSource="icon_stylus_mode.png"
                        ContentLayout="Left,8"
                        Text="手写模式"
                    />

                </Grid>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                    <Label
                        x:Name="InputModeFingerCheck"
                        Grid.Column="1"
                        VerticalOptions="Center"
                        Text="✓"
                        FontSize="14"
                        TextColor="{StaticResource PrimaryBlue}"
                        IsVisible="False"
                    />
                    <Button
                        x:Name="InputModeFingerButton"
                        Grid.Column="0"
                        Style="{StaticResource InputModeItemButton}"
                        ImageSource="icon_hand_mode.png"
                        ContentLayout="Left,8"
                        Text="触控模式"
                    />

                </Grid>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                    <Label
                        x:Name="InputModeReadCheck"
                        Grid.Column="1"
                        VerticalOptions="Center"
                        Text="✓"
                        FontSize="14"
                        TextColor="{StaticResource PrimaryBlue}"
                        IsVisible="False"
                    />
                    <Button
                        x:Name="InputModeReadButton"
                        Grid.Column="0"
                        Style="{StaticResource InputModeItemButton}"
                        ImageSource="icon_read_mode.png"
                        ContentLayout="Left,8"
                        Text="阅读模式"
                    />

                </Grid>
            </VerticalStackLayout>
        </Border>

        <Border
            x:Name="LayerPanel"
            IsVisible="False"
            ZIndex="37"
            InputTransparent="False"
            VerticalOptions="Start"
            HorizontalOptions="Start"
            WidthRequest="236"
            MaximumWidthRequest="252"
            Margin="0"
            Padding="12"
            Style="{StaticResource PanelCard}"
            BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceSoft}, Dark={StaticResource SurfaceSoftDark}}"
        >
            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
                <Label
                    x:Name="LayerTitleLabel"
                    Grid.Row="0"
                    Text="图层"
                    FontFamily="OpenSansSemibold"
                    FontSize="16"
                    TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                />
                <ScrollView Grid.Row="1">
                    <VerticalStackLayout x:Name="LayerList" Spacing="6" />
                </ScrollView>
                <HorizontalStackLayout
                    Grid.Row="2"
                    Spacing="8"
                    HorizontalOptions="Center"
                >
                    <ImageButton
                        x:Name="AddLayerButton"
                        Style="{StaticResource ToolbarIconButton}"
                        Source="icon_plus.png"
                    />
                    <ImageButton
                        x:Name="DeleteLayerButton"
                        Style="{StaticResource ToolbarIconButton}"
                        Source="icon_minus.png"
                    />
                </HorizontalStackLayout>
            </Grid>
        </Border>
    </Grid>
</ContentView>
