<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
>
    <Color x:Key="AccentBlue">#4A90E2</Color>
    <Color x:Key="AccentBlueSoft">#E8F4FD</Color>
    <Color x:Key="AccentBlueDark">#357ABD</Color>
    <Color x:Key="TextPrimaryLight">#1C1C1E</Color>
    <Color x:Key="TextPrimaryDark">#F2F2F7</Color>
    <Color x:Key="TextSecondaryLight">#636366</Color>
    <Color x:Key="TextSecondaryDark">#AEAEB2</Color>
    <Color x:Key="SurfaceSoft">#F7FAFF</Color>
    <Color x:Key="SurfaceSoftDark">#223247</Color>

    <Style x:Key="BaseButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="14" />
        <Setter
            Property="TextColor"
            Value="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
        />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="MinimumHeightRequest" Value="38" />
        <Setter Property="Shadow">
            <Shadow Brush="#1A0D223D" Radius="6" Offset="0,2" Opacity="0.65" />
        </Setter>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal">
                        <VisualState.Setters>
                            <Setter Property="Scale" Value="1" />
                            <Setter Property="TranslationY" Value="0" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="PointerOver">
                        <VisualState.Setters>
                            <Setter Property="Scale" Value="1.02" />
                            <Setter Property="TranslationY" Value="0" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="Scale" Value="0.96" />
                            <Setter Property="TranslationY" Value="1" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style x:Key="HeaderIconButton" TargetType="ImageButton">
        <Setter Property="WidthRequest" Value="34" />
        <Setter Property="HeightRequest" Value="34" />
        <Setter Property="MinimumWidthRequest" Value="34" />
        <Setter Property="MinimumHeightRequest" Value="34" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="7" />
        <Setter Property="Aspect" Value="AspectFit" />
        <Setter
            Property="BackgroundColor"
            Value="{AppThemeBinding Light={StaticResource BackgroundPrimary}, Dark=#E6EEF9}"
        />
        <Setter Property="BorderColor" Value="Transparent" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="Shadow">
            <Shadow Brush="#1411283E" Radius="5" Offset="0,2" Opacity="0.65" />
        </Setter>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal">
                        <VisualState.Setters>
                            <Setter Property="Scale" Value="1" />
                            <Setter Property="TranslationY" Value="0" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="PointerOver">
                        <VisualState.Setters>
                            <Setter Property="Scale" Value="1.03" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="Scale" Value="0.95" />
                            <Setter Property="TranslationY" Value="1" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style
        x:Key="ToolbarIconButton"
        TargetType="ImageButton"
        BasedOn="{StaticResource HeaderIconButton}"
    >
        <Setter Property="WidthRequest" Value="30" />
        <Setter Property="HeightRequest" Value="30" />
        <Setter Property="MinimumWidthRequest" Value="30" />
        <Setter Property="MinimumHeightRequest" Value="30" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="5" />
        <Setter
            Property="BackgroundColor"
            Value="{AppThemeBinding Light=#F4F5F8, Dark=#E6EEF9}"
        />
        <Setter Property="BorderColor" Value="Transparent" />
        <Setter Property="BorderWidth" Value="0" />
    </Style>

    <Style
        x:Key="ToolbarIconButtonSelected"
        TargetType="ImageButton"
        BasedOn="{StaticResource ToolbarIconButton}"
    >
        <Setter
            Property="BackgroundColor"
            Value="{AppThemeBinding Light={StaticResource ToolSelected}, Dark={StaticResource AccentBlueDark}}"
        />
        <Setter
            Property="BorderColor"
            Value="{AppThemeBinding Light={StaticResource PrimaryBlue}, Dark={StaticResource PrimaryBlueLight}}"
        />
        <Setter Property="BorderWidth" Value="1" />
    </Style>

    <Style x:Key="ToolbarToolIconButton" TargetType="ImageButton">
        <Setter Property="WidthRequest" Value="28" />
        <Setter Property="HeightRequest" Value="28" />
        <Setter Property="MinimumWidthRequest" Value="28" />
        <Setter Property="MinimumHeightRequest" Value="28" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="Aspect" Value="AspectFit" />
        <Setter
            Property="BackgroundColor"
            Value="{AppThemeBinding Light=#F7F9FC, Dark=#EAF1FB}"
        />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="BorderColor" Value="Transparent" />
        <Setter Property="Shadow">
            <Shadow Brush="#140D223D" Radius="4" Offset="0,1.5" Opacity="0.6" />
        </Setter>
    </Style>

    <Style
        x:Key="ToolbarToolIconButtonSelected"
        TargetType="ImageButton"
        BasedOn="{StaticResource ToolbarToolIconButton}"
    >
        <Setter
            Property="BackgroundColor"
            Value="{AppThemeBinding Light={StaticResource ToolSelected}, Dark={StaticResource AccentBlueDark}}"
        />
        <Setter
            Property="BorderColor"
            Value="{AppThemeBinding Light={StaticResource PrimaryBlue}, Dark={StaticResource PrimaryBlueLight}}"
        />
        <Setter Property="BorderWidth" Value="1" />
    </Style>

    <Style x:Key="PanelCard" TargetType="Border">
        <Setter
            Property="BackgroundColor"
            Value="{AppThemeBinding Light={StaticResource BackgroundPrimary}, Dark={StaticResource Gray800}}"
        />
        <Setter
            Property="Stroke"
            Value="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray700}}"
        />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 18" />
        <Setter Property="Shadow">
            <Shadow Brush="#1F2C3E1F" Radius="16" Offset="0,4" Opacity="0.85" />
        </Setter>
    </Style>

    <Style x:Key="FloatingIconButton" TargetType="ImageButton">
        <Setter Property="WidthRequest" Value="56" />
        <Setter Property="HeightRequest" Value="56" />
        <Setter Property="MinimumWidthRequest" Value="56" />
        <Setter Property="MinimumHeightRequest" Value="56" />
        <Setter Property="CornerRadius" Value="28" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Aspect" Value="AspectFit" />
        <Setter
            Property="BackgroundColor"
            Value="{StaticResource PrimaryBlue}"
        />
        <Setter Property="Shadow">
            <Shadow Brush="#334A90E2" Offset="0,8" Radius="20" Opacity="1" />
        </Setter>
    </Style>

    <Style
        x:Key="DrawerItemButton"
        TargetType="Button"
        BasedOn="{StaticResource BaseButtonStyle}"
    >
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="Padding" Value="10,11" />
        <Setter Property="FontSize" Value="15" />
    </Style>

    <Style x:Key="SettingRow" TargetType="Border">
        <Setter
            Property="BackgroundColor"
            Value="{AppThemeBinding Light={StaticResource BackgroundPrimary}, Dark={StaticResource Gray800}}"
        />
        <Setter
            Property="Stroke"
            Value="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray700}}"
        />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 14" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="ColorButton" TargetType="Button">
        <Setter Property="WidthRequest" Value="24" />
        <Setter Property="HeightRequest" Value="24" />
        <Setter Property="MinimumWidthRequest" Value="24" />
        <Setter Property="MinimumHeightRequest" Value="24" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="BorderWidth" Value="2" />
        <Setter Property="BorderColor" Value="Transparent" />
    </Style>

    <Style
        x:Key="InputModeItemButton"
        TargetType="Button"
        BasedOn="{StaticResource BaseButtonStyle}"
    >
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="Padding" Value="8,8" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style x:Key="SubtleLabelChip" TargetType="Border">
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        <Setter
            Property="BackgroundColor"
            Value="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource Gray700}}"
        />
        <Setter
            Property="Stroke"
            Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
        />
        <Setter Property="StrokeThickness" Value="1" />
    </Style>

    <Style x:Key="FlatTopIconButton" TargetType="ImageButton">
        <Setter Property="WidthRequest" Value="24" />
        <Setter Property="HeightRequest" Value="24" />
        <Setter Property="MinimumWidthRequest" Value="24" />
        <Setter Property="MinimumHeightRequest" Value="24" />
        <Setter Property="CornerRadius" Value="9" />
        <Setter Property="Padding" Value="2" />
        <Setter Property="Aspect" Value="AspectFit" />
        <Setter
            Property="BackgroundColor"
            Value="{AppThemeBinding Light=#F5F8FC, Dark=#EAF1FB}"
        />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="BorderColor" Value="Transparent" />
        <Setter Property="Shadow">
            <Shadow Brush="#120D223D" Radius="4" Offset="0,1.5" Opacity="0.6" />
        </Setter>
    </Style>

    <Style
        x:Key="HomeTopIconButton"
        TargetType="ImageButton"
        BasedOn="{StaticResource FlatTopIconButton}"
    >
        <Setter Property="WidthRequest" Value="22" />
        <Setter Property="HeightRequest" Value="22" />
        <Setter Property="MinimumWidthRequest" Value="22" />
        <Setter Property="MinimumHeightRequest" Value="22" />
        <Setter Property="Padding" Value="2" />
    </Style>

    <Style
        x:Key="FilterTabButton"
        TargetType="Button"
        BasedOn="{StaticResource BaseButtonStyle}"
    >
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="Padding" Value="4,0" />
        <Setter Property="MinimumHeightRequest" Value="30" />
        <Setter Property="FontSize" Value="15" />
        <Setter
            Property="TextColor"
            Value="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}"
        />
    </Style>
</ResourceDictionary>
